-- EXCLUSION MANAGER (v3 — click-to-remove, red hover, autofill)
-- ═══════════════════════════════════════════════════════════════
local function createExclusionManager(order, parent)
	local c = Instance.new("Frame"); c.LayoutOrder = order; c.Size = UDim2.new(1, 0, 0, 90); c.BackgroundTransparency = 1; c.ZIndex = 10; c.Parent = parent

	local lb = Instance.new("TextLabel"); lb.BackgroundTransparency = 1; lb.Size = UDim2.new(1, 0, 0, 16)
	lb.Text = "Exclusions (won't target these players)"; lb.TextColor3 = Color3.fromRGB(180,180,180)
	lb.Font = Enum.Font.GothamMedium; lb.TextSize = 13; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.ZIndex = 10; lb.Parent = c

	local inputRow = Instance.new("Frame"); inputRow.Size = UDim2.new(1, 0, 0, 26); inputRow.Position = UDim2.new(0, 0, 0, 20)
	inputRow.BackgroundTransparency = 1; inputRow.ZIndex = 10; inputRow.Parent = c

	-- Input box container (for ghost text overlay)
	local boxContainer = Instance.new("Frame"); boxContainer.Size = UDim2.new(1, -60, 1, 0)
	boxContainer.BackgroundTransparency = 1; boxContainer.ClipsDescendants = true; boxContainer.ZIndex = 10; boxContainer.Parent = inputRow

	local box = Instance.new("TextBox"); box.Size = UDim2.new(1, 0, 1, 0)
	box.BackgroundColor3 = Color3.fromRGB(10,10,10); box.PlaceholderText = "Player name..."
	box.PlaceholderColor3 = Color3.fromRGB(80,80,80); box.Text = ""; box.Font = Enum.Font.GothamMedium
	box.TextSize = 13; box.TextColor3 = Color3.fromRGB(220,220,220); box.ClearTextOnFocus = false
	box.TextXAlignment = Enum.TextXAlignment.Left; box.ZIndex = 11; box.Parent = boxContainer
	Instance.new("UICorner", box).CornerRadius = UDim.new(0, 6)
	Instance.new("UIStroke", box).Color = Color3.fromRGB(60,60,60)
	local pad = Instance.new("UIPadding"); pad.PaddingLeft = UDim.new(0, 8); pad.Parent = box

	-- Ghost text overlay for autocomplete
	local ghostLabel = Instance.new("TextLabel"); ghostLabel.Size = UDim2.new(1, 0, 1, 0)
	ghostLabel.BackgroundTransparency = 1; ghostLabel.Text = ""; ghostLabel.Font = Enum.Font.GothamMedium
	ghostLabel.TextSize = 13; ghostLabel.TextColor3 = Color3.fromRGB(60, 60, 60)
	ghostLabel.TextXAlignment = Enum.TextXAlignment.Left; ghostLabel.ZIndex = 10
	ghostLabel.TextTransparency = 0.5; ghostLabel.Parent = boxContainer
	local ghostPad = Instance.new("UIPadding"); ghostPad.PaddingLeft = UDim.new(0, 8); ghostPad.Parent = ghostLabel

	-- Autocomplete suggestion state
	local currentSuggestion = nil

	-- Autocomplete function
	local function findSuggestion(partial)
		if #partial == 0 then return nil end
		local lower = partial:lower()
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer then
				if player.Name:lower():sub(1, #lower) == lower then
					return player.Name
				end
				if player.DisplayName:lower():sub(1, #lower) == lower then
					return player.DisplayName
				end
			end
		end
		return nil
	end

	-- Update ghost text on every change
	box:GetPropertyChangedSignal("Text"):Connect(function()
		local typed = box.Text
		if #typed > 0 then
			local suggestion = findSuggestion(typed)
			if suggestion then
				-- Show ghost letters: the typed part is invisible (overlaps), plus the rest is ghost
				ghostLabel.Text = suggestion
				currentSuggestion = suggestion
			else
				ghostLabel.Text = ""
				currentSuggestion = nil
			end
		else
			ghostLabel.Text = ""
			currentSuggestion = nil
		end
	end)

	local addBtn = Instance.new("TextButton"); addBtn.Size = UDim2.new(0, 52, 1, 0); addBtn.Position = UDim2.new(1, -52, 0, 0)
	addBtn.BackgroundColor3 = Color3.fromRGB(10,10,10); addBtn.Text = "+ Add"; addBtn.Font = Enum.Font.GothamBold
	addBtn.TextSize = 12; addBtn.TextColor3 = Color3.fromRGB(200,200,200); addBtn.AutoButtonColor = false; addBtn.ZIndex = 11; addBtn.Parent = inputRow
	Instance.new("UICorner", addBtn).CornerRadius = UDim.new(0, 6)
	local abs = Instance.new("UIStroke"); abs.Color = Color3.fromRGB(60,60,60); abs.Thickness = 1; abs.Parent = addBtn

	-- Tags container (scrollable for many exclusions)
	local tagsFrame = Instance.new("Frame"); tagsFrame.Size = UDim2.new(1, 0, 0, 40)
	tagsFrame.Position = UDim2.new(0, 0, 0, 50); tagsFrame.BackgroundTransparency = 1; tagsFrame.ZIndex = 10; tagsFrame.Parent = c
	local tagsLayout = Instance.new("UIListLayout"); tagsLayout.FillDirection = Enum.FillDirection.Horizontal
	tagsLayout.Padding = UDim.new(0, 6); tagsLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tagsLayout.VerticalAlignment = Enum.VerticalAlignment.Top; tagsLayout.Wraps = true; tagsLayout.Parent = tagsFrame

	local function refreshTags()
		-- Clear old tags
		for _, child in ipairs(tagsFrame:GetChildren()) do
			if child:IsA("TextButton") then child:Destroy() end
		end

		if #Settings.Exclusions == 0 then
			local noTag = Instance.new("TextLabel"); noTag.BackgroundTransparency = 1
			noTag.Size = UDim2.new(1, 0, 0, 16); noTag.Text = "No exclusions"
			noTag.TextColor3 = Color3.fromRGB(80,80,80); noTag.Font = Enum.Font.Code
			noTag.TextSize = 12; noTag.TextXAlignment = Enum.TextXAlignment.Left; noTag.Name = "NoTag"; noTag.ZIndex = 10
			-- Remove existing
			local ex = tagsFrame:FindFirstChild("NoTag")
			if ex then ex:Destroy() end
			noTag.Parent = tagsFrame
			return
		end

		local ex = tagsFrame:FindFirstChild("NoTag")
		if ex then ex:Destroy() end

		for idx, name in ipairs(Settings.Exclusions) do
			local tag = Instance.new("TextButton")
			tag.Size = UDim2.new(0, #name * 8 + 24, 0, 20)
			tag.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
			tag.Text = name; tag.Font = Enum.Font.Code; tag.TextSize = 12
			tag.TextColor3 = Color3.fromRGB(180, 180, 180)
			tag.AutoButtonColor = false; tag.ZIndex = 11; tag.LayoutOrder = idx
			tag.Parent = tagsFrame
			Instance.new("UICorner", tag).CornerRadius = UDim.new(0, 5)
			local tagStroke = Instance.new("UIStroke"); tagStroke.Color = Color3.fromRGB(60,60,60); tagStroke.Thickness = 1; tagStroke.Parent = tag

			-- Hover: turn red
			tag.MouseEnter:Connect(function()
				TweenService:Create(tag, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(255, 80, 80), BackgroundColor3 = Color3.fromRGB(40, 10, 10)}):Play()
				TweenService:Create(tagStroke, TweenInfo.new(0.12), {Color = Color3.fromRGB(200, 60, 60)}):Play()
				tag.Text = name .. " ✕"
			end)
			tag.MouseLeave:Connect(function()
				TweenService:Create(tag, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(180, 180, 180), BackgroundColor3 = Color3.fromRGB(20, 20, 20)}):Play()
				TweenService:Create(tagStroke, TweenInfo.new(0.12), {Color = Color3.fromRGB(60,60,60)}):Play()
				tag.Text = name
			end)

			-- Click to remove
			tag.MouseButton1Click:Connect(function()
				for i, v in ipairs(Settings.Exclusions) do
					if v == name then
						table.remove(Settings.Exclusions, i)
						break
					end
				end
				refreshTags()
			end)
		end
	end
	refreshTags()

	local function addExclusion()
		local name = box.Text:gsub("^%s+", ""):gsub("%s+$", "")
		-- If there's a suggestion and user typed partial, use suggestion
		if #name == 0 and currentSuggestion then
			name = currentSuggestion
		end
		if #name > 0 then
			for _, v in ipairs(Settings.Exclusions) do if v:lower() == name:lower() then return end end
			table.insert(Settings.Exclusions, name)
			box.Text = ""; ghostLabel.Text = ""; currentSuggestion = nil
			refreshTags()
			task.spawn(function() abs.Color = Color3.fromRGB(255,255,255); task.wait(0.1); abs.Color = Color3.fromRGB(60,60,60) end)
		end
	end

	addBtn.MouseButton1Click:Connect(addExclusion)
	addBtn.MouseEnter:Connect(function() TweenService:Create(abs, TweenInfo.new(0.1), {Color = Color3.fromRGB(150,150,150)}):Play() end)
	addBtn.MouseLeave:Connect(function() TweenService:Create(abs, TweenInfo.new(0.1), {Color = Color3.fromRGB(60,60,60)}):Play() end)

	-- Enter key to autofill/add
	box.FocusLost:Connect(function(enterPressed)
		if enterPressed then
			-- If there's a suggestion, autofill it first
			if currentSuggestion and #box.Text > 0 then
				box.Text = currentSuggestion
				ghostLabel.Text = ""
				-- Then add it
				task.wait(0.05)
				addExclusion()
			elseif #box.Text:gsub("%s", "") > 0 then
				addExclusion()
			end
		end
	end)
end

