local activeDropdown = nil



-- COLLAPSIBLE SECTION: header with name, keybind, toggle, expand arrow
-- keybindKey: string key in tbl that holds keybind (e.g. "Keybind"), or nil for no keybind display
local function createSection(sectionTitle, keybindKey, order, parent, tbl, enabledKey)
	local isEnabled = tbl and tbl[enabledKey] or false
	local isExpanded = false
	local settingsLayout = nil
	local arrow = nil

	-- Container
	local section = Instance.new("Frame")
	section.LayoutOrder = order
	section.Size = UDim2.new(1, 0, 0, 36) -- collapsed: just header
	section.BackgroundColor3 = Color3.fromRGB(8, 8, 8)
	section.BackgroundTransparency = isEnabled and 0.3 or 0.6
	section.BorderSizePixel = 0
	section.ZIndex = 10
	section.ClipsDescendants = true
	section.Parent = parent

	-- Corner border
	local cornerColor = isEnabled and Color3.fromRGB(120,120,120) or Color3.fromRGB(50,50,50)
	local corners = addCornerBorder(section, cornerColor, 1, 10)

	-- Header row
	local header = Instance.new("TextButton")
	header.Size = UDim2.new(1, 0, 0, 36)
	header.BackgroundTransparency = 1
	header.Text = ""; header.AutoButtonColor = false
	header.ZIndex = 11; header.Parent = section

	-- Section title
	local titleLbl = Instance.new("TextLabel")
	titleLbl.BackgroundTransparency = 1
	titleLbl.Size = UDim2.new(0, 200, 1, 0)
	titleLbl.Position = UDim2.new(0, 12, 0, 0)
	titleLbl.Text = sectionTitle
	titleLbl.TextColor3 = isEnabled and Color3.fromRGB(240,240,240) or Color3.fromRGB(140,140,140)
	titleLbl.Font = Enum.Font.GothamBold
	titleLbl.TextSize = 14
	titleLbl.TextXAlignment = Enum.TextXAlignment.Left
	titleLbl.ZIndex = 12; titleLbl.Parent = header

	-- Keybind display in header
	local keybindLbl = nil
	if keybindKey then
		local keybindText = tbl and tbl[keybindKey] or "..."
		keybindLbl = Instance.new("TextLabel")
		keybindLbl.BackgroundTransparency = 1
		keybindLbl.Size = UDim2.new(0, 40, 0, 20)
		keybindLbl.Position = UDim2.new(1, -110, 0.5, -10)
		keybindLbl.Text = keybindText
		keybindLbl.TextColor3 = Color3.fromRGB(100,100,100)
		keybindLbl.Font = Enum.Font.Code; keybindLbl.TextSize = 12
		keybindLbl.ZIndex = 12; keybindLbl.Parent = header
	end

	-- Toggle switch
	local toggleBg = Instance.new("TextButton")
	toggleBg.Size = UDim2.new(0, 30, 0, 16)
	toggleBg.Position = UDim2.new(1, -60, 0.5, -8)
	toggleBg.BackgroundColor3 = isEnabled and Color3.fromRGB(60,60,60) or Color3.fromRGB(25,25,25)
	toggleBg.Text = ""; toggleBg.AutoButtonColor = false; toggleBg.ZIndex = 13; toggleBg.Parent = header
	Instance.new("UICorner", toggleBg).CornerRadius = UDim.new(0, 4)
	local toggleStroke = Instance.new("UIStroke"); toggleStroke.Color = isEnabled and Color3.fromRGB(200,200,200) or Color3.fromRGB(80,80,80); toggleStroke.Thickness = 1; toggleStroke.Parent = toggleBg

	local toggleKnob = Instance.new("Frame")
	toggleKnob.Size = UDim2.new(0, 12, 0, 12)
	toggleKnob.Position = isEnabled and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6)
	toggleKnob.BackgroundColor3 = isEnabled and Color3.fromRGB(255,255,255) or Color3.fromRGB(140,140,140)
	toggleKnob.ZIndex = 14; toggleKnob.Parent = toggleBg
	Instance.new("UICorner", toggleKnob).CornerRadius = UDim.new(0, 3)

	local function setExpanded(expand)
		if isExpanded == expand then return end
		isExpanded = expand
		section:SetAttribute("IsExpanded", isExpanded)
		local targetH = isExpanded and (38 + settingsLayout.AbsoluteContentSize.Y + 10) or 36
		arrow.Text = isExpanded and "▲" or "▼"
		if not isExpanded then
			section.ClipsDescendants = true
		end
		local tween = TweenService:Create(section, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, targetH)})
		tween:Play()
		if isExpanded then
			task.spawn(function()
				tween.Completed:Wait()
				if section:GetAttribute("IsExpanded") == true then
					section.ClipsDescendants = false
				end
			end)
		end
		TweenService:Create(arrow, TweenInfo.new(0.15), {TextColor3 = isExpanded and Color3.fromRGB(200,200,200) or Color3.fromRGB(100,100,100)}):Play()
	end

	-- FIX: Toggle does NOT auto-expand. User clicks header to expand manually.
	toggleBg.MouseButton1Click:Connect(function()
		isEnabled = not isEnabled
		if tbl then tbl[enabledKey] = isEnabled end
		TweenService:Create(toggleKnob, TweenInfo.new(0.18), {
			Position = isEnabled and UDim2.new(1, -14, 0.5, -6) or UDim2.new(0, 2, 0.5, -6),
			BackgroundColor3 = isEnabled and Color3.fromRGB(255,255,255) or Color3.fromRGB(140,140,140)
		}):Play()
		TweenService:Create(toggleBg, TweenInfo.new(0.18), {BackgroundColor3 = isEnabled and Color3.fromRGB(60,60,60) or Color3.fromRGB(25,25,25)}):Play()
		TweenService:Create(toggleStroke, TweenInfo.new(0.18), {Color = isEnabled and Color3.fromRGB(200,200,200) or Color3.fromRGB(80,80,80)}):Play()
		TweenService:Create(section, TweenInfo.new(0.18), {BackgroundTransparency = isEnabled and 0.3 or 0.6}):Play()
		TweenService:Create(titleLbl, TweenInfo.new(0.18), {TextColor3 = isEnabled and Color3.fromRGB(240,240,240) or Color3.fromRGB(140,140,140)}):Play()
		for _, c in ipairs(corners) do
			TweenService:Create(c, TweenInfo.new(0.18), {BackgroundColor3 = isEnabled and Color3.fromRGB(120,120,120) or Color3.fromRGB(50,50,50)}):Play()
		end
		-- Removed: setExpanded(isEnabled) — user opens settings manually
	end)

	-- Expand arrow
	arrow = Instance.new("TextLabel")
	arrow.BackgroundTransparency = 1
	arrow.Size = UDim2.new(0, 20, 1, 0)
	arrow.Position = UDim2.new(1, -25, 0, 0)
	arrow.Text = "▼"; arrow.TextColor3 = Color3.fromRGB(100,100,100)
	arrow.Font = Enum.Font.GothamBold; arrow.TextSize = 10; arrow.ZIndex = 12; arrow.Parent = header

	-- Settings container
	local settingsFrame = Instance.new("Frame")
	settingsFrame.Name = "Settings"
	settingsFrame.Size = UDim2.new(1, -16, 0, 0)
	settingsFrame.Position = UDim2.new(0, 8, 0, 38)
	settingsFrame.BackgroundTransparency = 1; settingsFrame.ZIndex = 10
	settingsFrame.Parent = section

	settingsLayout = Instance.new("UIListLayout")
	settingsLayout.Padding = UDim.new(0, 3)
	settingsLayout.SortOrder = Enum.SortOrder.LayoutOrder
	settingsLayout.Parent = settingsFrame

	-- Auto-size settings frame
	settingsLayout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function()
		local contentH = settingsLayout.AbsoluteContentSize.Y
		settingsFrame.Size = UDim2.new(1, -16, 0, contentH)
		if isExpanded then
			local targetH = 38 + contentH + 10
			TweenService:Create(section, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, targetH)}):Play()
		end
	end)

	-- Expand/collapse on header click
	header.MouseButton1Click:Connect(function()
		setExpanded(not isExpanded)
	end)

	-- No auto-expand on init either (removed)

	return settingsFrame, section, keybindLbl
end
