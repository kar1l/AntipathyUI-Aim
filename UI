	hb.Size = UDim2.new(0, 78, 0, 20); hb.Position = UDim2.new(1, -78, 0.5, -10)
	hb.BackgroundColor3 = Color3.fromRGB(10,10,10)
	hb.Text = ""; hb.PlaceholderText = "#"..currentHex; hb.PlaceholderColor3 = Color3.fromRGB(70,70,70)
	hb.Font = Enum.Font.Code; hb.TextSize = 12; hb.TextColor3 = Color3.fromRGB(190,190,190)
	hb.ClearTextOnFocus = false; hb.TextXAlignment = Enum.TextXAlignment.Center; hb.ZIndex = 11; hb.Parent = c
	Instance.new("UICorner", hb).CornerRadius = UDim.new(0, 5)
	local hbs = Instance.new("UIStroke"); hbs.Color = Color3.fromRGB(55,55,55); hbs.Thickness = 1; hbs.Parent = hb

	local function updateColor(newHex, fromPicker)
		currentHex = newHex; if tbl then tbl[key] = currentHex end
		sw.BackgroundColor3 = hexToColor3(currentHex); hb.PlaceholderText = "#"..currentHex
		if fromPicker then hb.Text = "" else hb.Text = "#"..currentHex end
	end

	hb.FocusLost:Connect(function()
		local raw = hb.Text:gsub("#",""):gsub("%s",""):upper()
		if raw == "" then updateColor(currentHex, true)
		elseif #raw == 6 and raw:match("^%x+$") then updateColor(raw, false)
			task.spawn(function() hbs.Color = Color3.fromRGB(255,255,255); task.wait(0.08); hbs.Color = Color3.fromRGB(55,55,55) end)
		else hb.Text = ""; task.spawn(function() hbs.Color = Color3.fromRGB(255,80,80); task.wait(0.3); hbs.Color = Color3.fromRGB(55,55,55) end) end
	end)
	hb.Focused:Connect(function() TweenService:Create(hbs, TweenInfo.new(0.1), {Color = Color3.fromRGB(160,160,160)}):Play() end)

	-- Single click: open color picker
	sw.MouseButton1Click:Connect(function()
		if rainbowActive then
			rainbowActive = false
			if rainbowConn then rainbowConn:Disconnect(); rainbowConn = nil end
			return
		end
		openColorPicker(hexToColor3(currentHex), function(c3)
			updateColor(color3ToHex(c3), true)
		end)
	end)

	-- Double click: toggle rainbow
	local lastClick = 0
	sw.MouseButton1Click:Connect(function()
		local now = tick()
		if now - lastClick < 0.35 then
			-- Double click detected
			if rainbowActive then
				rainbowActive = false
				if rainbowConn then rainbowConn:Disconnect(); rainbowConn = nil end
			else
				rainbowActive = true
				cp.Visible = false; pickerActive = false
				rainbowConn = RunService.Heartbeat:Connect(function()
					if not rainbowActive then return end
					local hue = (tick() * 0.5) % 1
					local c3 = Color3.fromHSV(hue, 1, 1)
					sw.BackgroundColor3 = c3
					local hex = color3ToHex(c3)
					if tbl then tbl[key] = hex end
					hb.PlaceholderText = "#"..hex; hb.Text = ""
				end)
			end
		end
		lastClick = now
	end)
end

