	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 70, 0, 28)
	btn.Position = UDim2.new(0, xOffset, 0.5, -14)
	btn.BackgroundTransparency = 1
	btn.TextColor3 = isActive and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(120, 120, 120)
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 14
	btn.Text = text
	btn.AutoButtonColor = false
	btn.ZIndex = 55
	btn.Parent = topbar

	local ts = Instance.new("UIStroke")
	ts.Color = Color3.fromRGB(200, 200, 200)
	ts.Thickness = 1
	ts.Transparency = isActive and 0.3 or 1
	ts.Parent = btn

	local line = Instance.new("Frame")
	line.Size = UDim2.new(0.65, 0, 0, 3)
	line.Position = UDim2.new(0.175, 0, 1, 0)
	line.BackgroundColor3 = isActive and Color3.fromRGB(255, 255, 255) or Color3.fromRGB(70, 70, 70)
	line.BorderSizePixel = 0
	line.ZIndex = 55
	line.Parent = btn
	Instance.new("UICorner", line).CornerRadius = UDim.new(1, 0)

	task.spawn(function()
		while btn.Parent do
			if btn:GetAttribute("IsActiveTab") then
				local v = math.random(200, 255)
				line.BackgroundColor3 = Color3.fromRGB(v, v, v)
				line.Size = UDim2.new(math.random(55, 70) / 100, 0, 0, math.random(2, 4))
				ts.Transparency = math.random() * 0.3
				if math.random(1, 6) == 1 then
					for _ = 1, math.random(2, 4) do
						line.BackgroundColor3 = math.random(2)==1 and Color3.fromRGB(255,255,255) or Color3.fromRGB(160,160,160)
						line.Position = UDim2.new(0.175 + math.random(-2,2)*0.01, 0, 1, math.random(-1,1))
						task.wait(0.04)
					end
					line.Position = UDim2.new(0.175, 0, 1, 0)
					line.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
					line.Size = UDim2.new(0.65, 0, 0, 3)
				end
				task.wait(0.08 + math.random() * 0.15)
			else
				line.BackgroundColor3 = Color3.fromRGB(70, 70, 70)
				ts.Transparency = 1
				task.wait(0.3 + math.random() * 0.4)
			end
		end
	end)
	btn:SetAttribute("IsActiveTab", isActive)
	return btn, line, ts
end

