local function createHexColor(text, order, parent, tbl, key)
	local currentHex = tbl and tbl[key] or "FFFFFF"
	local rainbowActive = false
	local rainbowConn = nil

	local c = Instance.new("Frame"); c.LayoutOrder = order; c.Size = UDim2.new(1, 0, 0, 22); c.BackgroundTransparency = 1; c.ZIndex = 10; c.Parent = parent
