	vl.Position = UDim2.new(0.85, 0, 0, 0)
	if step < 1 then vl.Text = string.format("%.2f", value)..suffix else vl.Text = tostring(value)..suffix end
	vl.TextColor3 = Color3.fromRGB(180,180,180); vl.Font = Enum.Font.GothamBold; vl.TextSize = 12
	vl.TextXAlignment = Enum.TextXAlignment.Right; vl.ZIndex = 10; vl.Parent = c
	local sb = Instance.new("Frame"); sb.Size = UDim2.new(0.40, 0, 0, 5); sb.Position = UDim2.new(0.45, 0, 0.5, -2)
	sb.BackgroundColor3 = Color3.fromRGB(20,20,20); sb.BorderSizePixel = 0; sb.ZIndex = 10; sb.Parent = c
	Instance.new("UICorner", sb).CornerRadius = UDim.new(0, 2)
	Instance.new("UIStroke", sb).Color = Color3.fromRGB(45,45,45)
	local pct = math.clamp((value - min) / (max - min), 0, 1)
	local sf = Instance.new("Frame"); sf.Size = UDim2.new(pct, 0, 1, 0); sf.BackgroundColor3 = Color3.fromRGB(180,180,180); sf.BorderSizePixel = 0; sf.ZIndex = 11; sf.Parent = sb
	Instance.new("UICorner", sf).CornerRadius = UDim.new(0, 2)
	local fg = Instance.new("UIGradient"); fg.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(160,160,160))}; fg.Parent = sf
	local kn = Instance.new("Frame"); kn.Size = UDim2.new(0, 12, 0, 12); kn.Position = UDim2.new(pct, -6, 0.5, -6)
	kn.BackgroundColor3 = Color3.fromRGB(255,255,255); kn.BorderSizePixel = 0; kn.ZIndex = 12; kn.Parent = sb
	Instance.new("UICorner", kn).CornerRadius = UDim.new(0, 2)
	local ks = Instance.new("UIStroke"); ks.Color = Color3.fromRGB(80,80,80); ks.Thickness = 1; ks.Parent = kn
	local sliding = false
	local ib = Instance.new("TextButton"); ib.Size = UDim2.new(1, 10, 0, 18); ib.Position = UDim2.new(0, -5, 0, 5)
	ib.BackgroundTransparency = 1; ib.Text = ""; ib.ZIndex = 13; ib.Parent = c
	local function upd(px)
		local ap = sb.AbsolutePosition.X; local as = sb.AbsoluteSize.X; if as == 0 then return end
		local np = math.clamp((px - ap) / as, 0, 1)
		value = math.floor((min + np * (max - min)) / step + 0.5) * step
		value = math.clamp(value, min, max); np = (value - min) / (max - min)
		sf.Size = UDim2.new(np, 0, 1, 0); kn.Position = UDim2.new(np, -6, 0.5, -6)
		if step < 1 then vl.Text = string.format("%.2f", value)..suffix else vl.Text = tostring(value)..suffix end
		if tbl then tbl[key] = value end
	end
	ib.MouseButton1Down:Connect(function() sliding = true end)
	UserInputService.InputChanged:Connect(function(input)
		if sliding and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then upd(input.Position.X) end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 and sliding then sliding = false end
	end)
end

