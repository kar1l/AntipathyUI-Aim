-- Compact slider (shorter)
local function createSlider(text, order, parent, min, max, tbl, key, step, suffix, wScale, wOff, textAbove)
	step = step or 1; suffix = suffix or ""
	local value = tbl and tbl[key] or min
	wScale = wScale or 1
	wOff = wOff or 0
	
	local containerHeight = textAbove and 40 or 28
	local c = Instance.new("Frame")
	c.LayoutOrder = order
	c.Size = UDim2.new(wScale, wOff, 0, containerHeight)
	c.BackgroundTransparency = 1
	c.ZIndex = 10
	c.Parent = parent

	local lb = Instance.new("TextLabel")
	lb.BackgroundTransparency = 1
	lb.TextColor3 = Color3.fromRGB(200, 200, 200)
	lb.Font = Enum.Font.GothamMedium
	lb.TextSize = 13
	lb.ZIndex = 10
	lb.Parent = c

	local sb = Instance.new("Frame")
	sb.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
	sb.BorderSizePixel = 0
	sb.ZIndex = 10
	sb.Parent = c
	Instance.new("UICorner", sb).CornerRadius = UDim.new(0, 2)
	local sbstroke = Instance.new("UIStroke", sb)
	sbstroke.Color = Color3.fromRGB(45, 45, 45)
	sbstroke.Thickness = 1

	local vl = nil
	if textAbove then
		-- Text above and centered
		lb.Size = UDim2.new(1, 0, 0, 14)
		lb.Position = UDim2.new(0, 0, 0, 0)
		lb.TextXAlignment = Enum.TextXAlignment.Center
		lb.Text = text .. " (" .. tostring(value) .. suffix .. ")"
		
		-- Slider bar below and centered
		sb.Size = UDim2.new(0.9, 0, 0, 5)
		sb.Position = UDim2.new(0.05, 0, 0, 24)
	else
		-- Normal layout
		lb.Size = UDim2.new(0.45, 0, 0, 14)
		lb.Position = UDim2.new(0, 0, 0.5, -7)
		lb.TextXAlignment = Enum.TextXAlignment.Left
		lb.Text = text
		
		vl = Instance.new("TextLabel")
		vl.BackgroundTransparency = 1
		vl.Size = UDim2.new(0.15, 0, 0, 14)
		vl.Position = UDim2.new(0.85, 0, 0.5, -7)
		vl.TextColor3 = Color3.fromRGB(180, 180, 180)
		vl.Font = Enum.Font.GothamBold
		vl.TextSize = 12
		vl.TextXAlignment = Enum.TextXAlignment.Right
		vl.ZIndex = 10
		vl.Parent = c
		if step < 1 then vl.Text = string.format("%.2f", value)..suffix else vl.Text = tostring(value)..suffix end
		
		sb.Size = UDim2.new(0.40, 0, 0, 5)
		sb.Position = UDim2.new(0.45, 0, 0.5, -2)
	end

	local pct = math.clamp((value - min) / (max - min), 0, 1)
	local sf = Instance.new("Frame")
	sf.Size = UDim2.new(pct, 0, 1, 0)
	sf.BackgroundColor3 = Color3.fromRGB(180, 180, 180)
	sf.BorderSizePixel = 0
	sf.ZIndex = 11
	sf.Parent = sb
	Instance.new("UICorner", sf).CornerRadius = UDim.new(0, 2)
	
	local fg = Instance.new("UIGradient")
	fg.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromRGB(255, 255, 255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(160, 160, 160))}
	fg.Parent = sf
	
	local kn = Instance.new("Frame")
	kn.Size = UDim2.new(0, 12, 0, 12)
	kn.Position = UDim2.new(pct, -6, 0.5, -6)
	kn.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
	kn.BorderSizePixel = 0
	kn.ZIndex = 12
	kn.Parent = sb
	Instance.new("UICorner", kn).CornerRadius = UDim.new(0, 2)
	local ks = Instance.new("UIStroke"); ks.Color = Color3.fromRGB(80, 80, 80); ks.Thickness = 1; ks.Parent = kn
	
	local sliding = false
	local ib = Instance.new("TextButton")
	ib.Size = UDim2.new(1, 10, 1, 0)
	ib.Position = UDim2.new(0, -5, 0, 0)
	ib.BackgroundTransparency = 1
	ib.Text = ""
	ib.ZIndex = 13
	ib.Parent = c
	
	local function upd(px)
		local ap = sb.AbsolutePosition.X
		local as = sb.AbsoluteSize.X
		if as == 0 then return end
		local np = math.clamp((px - ap) / as, 0, 1)
		value = math.floor((min + np * (max - min)) / step + 0.5) * step
		value = math.clamp(value, min, max)
		np = (value - min) / (max - min)
		
		sf.Size = UDim2.new(np, 0, 1, 0)
		kn.Position = UDim2.new(np, -6, 0.5, -6)
		
		if textAbove then
			lb.Text = text .. " (" .. tostring(value) .. suffix .. ")"
		else
			if vl then
				if step < 1 then vl.Text = string.format("%.2f", value)..suffix else vl.Text = tostring(value)..suffix end
			end
		end
		
		if tbl then tbl[key] = value end
	end
	
	ib.MouseButton1Down:Connect(function()
		_activeSliderUpdate = function(px) upd(px) end
	end)
end

-- Dropdown with animation
local function createDropdown(text, order, parent, options, tbl, key, wScale, wOff)
	local selected = tbl and tbl[key] or options[1]
	local expanded = false
	wScale = wScale or 1
	wOff = wOff or 0
	local c = Instance.new("Frame"); c.LayoutOrder = order; c.Size = UDim2.new(wScale, wOff, 0, 30); c.BackgroundTransparency = 1; c.ClipsDescendants = true; c.ZIndex = 15; c.Parent = parent
	c:SetAttribute("Expanded", false)

	local db = Instance.new("TextButton"); db.Size = UDim2.new(1, 0, 0, 28)
	db.BackgroundColor3 = Color3.fromRGB(15,15,18); db.Text = ""; db.AutoButtonColor = false; db.ZIndex = 16; db.Parent = c
	Instance.new("UICorner", db).CornerRadius = UDim.new(0, 6)
	local ds = Instance.new("UIStroke"); ds.Color = Color3.fromRGB(55,55,60); ds.Thickness = 1; ds.Transparency = 0.3; ds.Parent = db

	local dbLabel = Instance.new("TextLabel"); dbLabel.BackgroundTransparency = 1
	dbLabel.Size = UDim2.new(1, -30, 1, 0); dbLabel.Position = UDim2.new(0, 10, 0, 0)
	dbLabel.Text = text..":  "..selected; dbLabel.Font = Enum.Font.GothamBold; dbLabel.TextSize = 13
	dbLabel.TextColor3 = Color3.fromRGB(210,210,215); dbLabel.TextXAlignment = Enum.TextXAlignment.Left
	dbLabel.ZIndex = 17; dbLabel.Parent = db

	local arrowLbl = Instance.new("TextLabel"); arrowLbl.BackgroundTransparency = 1
	arrowLbl.Size = UDim2.new(0, 20, 1, 0); arrowLbl.Position = UDim2.new(1, -25, 0, 0)
	arrowLbl.Text = "▼"; arrowLbl.TextColor3 = Color3.fromRGB(110,110,115)
	arrowLbl.Font = Enum.Font.GothamBold; arrowLbl.TextSize = 9; arrowLbl.ZIndex = 17; arrowLbl.Parent = db

	-- Options container (inline, below button)
	local dl = Instance.new("Frame"); dl.Size = UDim2.new(1, 0, 0, 0)
	dl.Position = UDim2.new(0, 0, 0, 30); dl.BackgroundColor3 = Color3.fromRGB(12,12,14)
	dl.BorderSizePixel = 0; dl.ClipsDescendants = true; dl.ZIndex = 16; dl.Parent = c
	dl.Name = "DropdownList"
	Instance.new("UICorner", dl).CornerRadius = UDim.new(0, 6)
	Instance.new("UIStroke", dl).Color = Color3.fromRGB(55,55,60)
	local dlLayout = Instance.new("UIListLayout"); dlLayout.Padding = UDim.new(0, 2); dlLayout.SortOrder = Enum.SortOrder.LayoutOrder; dlLayout.Parent = dl
	local dlPad = Instance.new("UIPadding"); dlPad.PaddingTop = UDim.new(0, 3); dlPad.PaddingLeft = UDim.new(0, 3); dlPad.PaddingRight = UDim.new(0, 3); dlPad.Parent = dl

	local expandedH = #options * 26 + 8
	c:SetAttribute("ExpandedH", expandedH)
	
	if parent:FindFirstChildOfClass("UIListLayout") and parent:FindFirstChildOfClass("UIListLayout").FillDirection == Enum.FillDirection.Horizontal then
		if not parent:GetAttribute("DefaultHeight") then
			parent:SetAttribute("DefaultHeight", parent.Size.Y.Offset)
		end
	end

	local function updateRowHeight(isExpanding)
		local isRow = parent:FindFirstChildOfClass("UIListLayout") and parent:FindFirstChildOfClass("UIListLayout").FillDirection == Enum.FillDirection.Horizontal
		if not isRow then return end
		local maxH = parent:GetAttribute("DefaultHeight") or 30
		for _, child in ipairs(parent:GetChildren()) do
			if child:IsA("Frame") and child:GetAttribute("Expanded") then
				local eh = child:GetAttribute("ExpandedH") or 0
				local h = 30 + eh + 4
				if h > maxH then maxH = h end
			end
		end
		local tweenTime = isExpanding and 0.15 or 0.12
		local easingDir = isExpanding and Enum.EasingDirection.Out or Enum.EasingDirection.In
		TweenService:Create(parent, TweenInfo.new(tweenTime, Enum.EasingStyle.Quad, easingDir), {Size = UDim2.new(1, 0, 0, maxH)}):Play()
	end

	local function collapse()
		expanded = false; arrowLbl.Text = "▼"
		c:SetAttribute("Expanded", false)
		TweenService:Create(dl, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(1, 0, 0, 0)}):Play()
		TweenService:Create(c, TweenInfo.new(0.12, Enum.EasingStyle.Quad, Enum.EasingDirection.In), {Size = UDim2.new(wScale, wOff, 0, 30)}):Play()
		TweenService:Create(ds, TweenInfo.new(0.12), {Color = Color3.fromRGB(55,55,60)}):Play()
		updateRowHeight(false)
	end

	for i, opt in ipairs(options) do
		local ob = Instance.new("TextButton"); ob.LayoutOrder = i; ob.Size = UDim2.new(1, 0, 0, 24)
		ob.BackgroundColor3 = Color3.fromRGB(20,20,22); ob.Text = opt; ob.Font = Enum.Font.GothamMedium; ob.TextSize = 12
		ob.TextColor3 = Color3.fromRGB(190,190,195); ob.AutoButtonColor = false; ob.ZIndex = 17; ob.Parent = dl
		Instance.new("UICorner", ob).CornerRadius = UDim.new(0, 4)
		ob.MouseEnter:Connect(function() TweenService:Create(ob, TweenInfo.new(0.08), {BackgroundColor3 = Color3.fromRGB(40,40,44), TextColor3 = Color3.fromRGB(255,255,255)}):Play() end)
		ob.MouseLeave:Connect(function() TweenService:Create(ob, TweenInfo.new(0.08), {BackgroundColor3 = Color3.fromRGB(20,20,22), TextColor3 = Color3.fromRGB(190,190,195)}):Play() end)
		ob.MouseButton1Click:Connect(function()
			selected = opt; if tbl then tbl[key] = opt end; dbLabel.Text = text..":  "..opt
			collapse()
		end)
	end

	db.MouseEnter:Connect(function() TweenService:Create(db, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(25,25,28)}):Play() end)
	db.MouseLeave:Connect(function() if not expanded then TweenService:Create(db, TweenInfo.new(0.1), {BackgroundColor3 = Color3.fromRGB(15,15,18)}):Play() end end)
	db.MouseButton1Click:Connect(function()
		expanded = not expanded
		if expanded then
			c:SetAttribute("Expanded", true)
			dl.Size = UDim2.new(1, 0, 0, 0)
			arrowLbl.Text = "▲"
			TweenService:Create(dl, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(1, 0, 0, expandedH)}):Play()
			TweenService:Create(c, TweenInfo.new(0.15, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {Size = UDim2.new(wScale, wOff, 0, 30 + expandedH + 4)}):Play()
			TweenService:Create(ds, TweenInfo.new(0.1), {Color = Color3.fromRGB(160,160,165)}):Play()
			updateRowHeight(true)
		else
			collapse()
		end
	end)
end

-- Keybind button with mouse button support and optional callback
local function createKeybindButton(text, order, parent, tbl, key, onChanged, wScale, wOff)
	local curKey = tbl and tbl[key] or "..."
	local listening = false
