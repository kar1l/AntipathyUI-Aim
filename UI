-- Hex color input with preview swatch and interactive color picker
local function createHexColor(text, order, parent, tbl, key)
	local defaultHex = tbl and tbl[key] or "FFFFFF"
	local currentHex = defaultHex

	local c = Instance.new("Frame"); c.LayoutOrder = order; c.Size = UDim2.new(1, 0, 0, 22); c.BackgroundTransparency = 1; c.Parent = parent
	local lb = Instance.new("TextLabel"); lb.BackgroundTransparency = 1; lb.Size = UDim2.new(1, -110, 1, 0)
	lb.Text = text; lb.TextColor3 = Color3.fromRGB(210,210,210); lb.Font = Enum.Font.GothamMedium
	lb.TextSize = 14; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.Parent = c

	-- Turn sw into a button to pick color
	local sw = Instance.new("TextButton")
	sw.Size = UDim2.new(0, 16, 0, 16)
	sw.Position = UDim2.new(1, -105, 0.5, -8)
	sw.BackgroundColor3 = hexToColor3(defaultHex)
	sw.Text = ""
	sw.AutoButtonColor = false
	sw.Parent = c
	Instance.new("UICorner", sw).CornerRadius = UDim.new(0, 3)
	local swStroke = Instance.new("UIStroke")
	swStroke.Color = Color3.fromRGB(80,80,80)
	swStroke.Parent = sw

	local hb = Instance.new("TextBox")
	hb.Size = UDim2.new(0, 80, 0, 20)
	hb.Position = UDim2.new(1, -80, 0.5, -10)
	hb.BackgroundColor3 = Color3.fromRGB(10,10,10)
	hb.Text = "" -- start as empty for placeholder to show
	hb.PlaceholderText = "#" .. defaultHex
	hb.PlaceholderColor3 = Color3.fromRGB(100, 100, 100)
	hb.Font = Enum.Font.Code
	hb.TextSize = 13
	hb.TextColor3 = Color3.fromRGB(200,200,200)
	hb.ClearTextOnFocus = false
	hb.TextXAlignment = Enum.TextXAlignment.Center
	hb.Parent = c
	Instance.new("UICorner", hb).CornerRadius = UDim.new(0, 5)
	local hbs = Instance.new("UIStroke"); hbs.Color = Color3.fromRGB(60,60,60); hbs.Thickness = 1; hbs.Parent = hb

	local function updateColor(newHex, fromPicker)
		currentHex = newHex
		if tbl then tbl[key] = currentHex end
		sw.BackgroundColor3 = hexToColor3(currentHex)
		hb.PlaceholderText = "#" .. currentHex
		if fromPicker then
			hb.Text = "" -- clear text so placeholder shows new color hex
		else
			hb.Text = "#" .. currentHex
		end
	end

	hb.FocusLost:Connect(function()
		local raw = hb.Text:gsub("#", ""):gsub("%s", ""):upper()
		if raw == "" then
			-- user cleared it, fall back to defaultHex
			updateColor(defaultHex, true)
			task.spawn(function() hbs.Color = Color3.fromRGB(255,255,255); task.wait(0.08); hbs.Color = Color3.fromRGB(60,60,60) end)
		elseif #raw == 6 and raw:match("^%x+$") then
			updateColor(raw, false)
			task.spawn(function() hbs.Color = Color3.fromRGB(255,255,255); task.wait(0.08); hbs.Color = Color3.fromRGB(60,60,60) end)
		else
			-- revert
			if currentHex == defaultHex then
				hb.Text = ""
			else
				hb.Text = "#" .. currentHex
			end
			task.spawn(function() hbs.Color = Color3.fromRGB(255,80,80); task.wait(0.3); hbs.Color = Color3.fromRGB(60,60,60) end)
		end
	end)
	hb.Focused:Connect(function() TweenService:Create(hbs, TweenInfo.new(0.1), {Color = Color3.fromRGB(180,180,180)}):Play() end)

	sw.MouseButton1Click:Connect(function()
		openColorPicker(hexToColor3(currentHex), function(c3)
			local newHex = color3ToHex(c3)
			updateColor(newHex, true)
		end)
	end)
end

-- Exclusion list manager with autocomplete, ghost letters, and interactive removal tags
local function createExclusionManager(order, parent)
	local c = Instance.new("Frame"); c.LayoutOrder = order; c.Size = UDim2.new(1, 0, 0, 76); c.BackgroundTransparency = 1; c.Parent = parent

	local lb = Instance.new("TextLabel"); lb.BackgroundTransparency = 1; lb.Size = UDim2.new(1, 0, 0, 14)
	lb.Text = "Exclusions (won't target these players)"; lb.TextColor3 = Color3.fromRGB(180,180,180)
	lb.Font = Enum.Font.GothamMedium; lb.TextSize = 13; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.Parent = c

	local inputRow = Instance.new("Frame"); inputRow.Size = UDim2.new(1, 0, 0, 22); inputRow.Position = UDim2.new(0, 0, 0, 18)
	inputRow.BackgroundTransparency = 1; inputRow.Parent = c

	local box = Instance.new("TextBox"); box.Size = UDim2.new(1, -60, 1, 0)
	box.BackgroundColor3 = Color3.fromRGB(10,10,10); box.PlaceholderText = "Player name..."
	box.PlaceholderColor3 = Color3.fromRGB(80,80,80); box.Text = ""; box.Font = Enum.Font.GothamMedium
	box.TextSize = 13; box.TextColor3 = Color3.fromRGB(220,220,220); box.ClearTextOnFocus = false
	box.TextXAlignment = Enum.TextXAlignment.Left; box.Parent = inputRow
	Instance.new("UICorner", box).CornerRadius = UDim.new(0, 5)
	local boxStroke = Instance.new("UIStroke"); boxStroke.Color = Color3.fromRGB(60,60,60); boxStroke.Parent = box
	local pad = Instance.new("UIPadding"); pad.PaddingLeft = UDim.new(0, 8); pad.Parent = box

	-- Ghost label for autocomplete suggestions (placed overlaying the box)
	local ghostLabel = Instance.new("TextLabel")
	ghostLabel.Size = box.Size
	ghostLabel.Position = box.Position
	ghostLabel.BackgroundTransparency = 1
	ghostLabel.Text = ""
	ghostLabel.TextColor3 = Color3.fromRGB(110, 110, 110)
	ghostLabel.Font = box.Font
	ghostLabel.TextSize = box.TextSize
	ghostLabel.TextXAlignment = box.TextXAlignment
	ghostLabel.ZIndex = box.ZIndex + 1
	ghostLabel.Active = false
	ghostLabel.Selectable = false
	ghostLabel.Parent = inputRow
	local ghostPad = Instance.new("UIPadding"); ghostPad.PaddingLeft = UDim.new(0, 8); ghostPad.Parent = ghostLabel

	local addBtn = Instance.new("TextButton"); addBtn.Size = UDim2.new(0, 50, 1, 0); addBtn.Position = UDim2.new(1, -50, 0, 0)
	addBtn.BackgroundColor3 = Color3.fromRGB(10,10,10); addBtn.Text = "+ Add"; addBtn.Font = Enum.Font.GothamBold
	addBtn.TextSize = 12; addBtn.TextColor3 = Color3.fromRGB(200,200,200); addBtn.AutoButtonColor = false; addBtn.Parent = inputRow
	Instance.new("UICorner", addBtn).CornerRadius = UDim.new(0, 5)
	local abs = Instance.new("UIStroke"); abs.Color = Color3.fromRGB(60,60,60); abs.Thickness = 1; abs.Parent = addBtn

	local tagsScroll = Instance.new("ScrollingFrame")
	tagsScroll.Size = UDim2.new(1, 0, 0, 24)
	tagsScroll.Position = UDim2.new(0, 0, 0, 46)
	tagsScroll.BackgroundTransparency = 1
	tagsScroll.BorderSizePixel = 0
	tagsScroll.ScrollBarThickness = 2
	tagsScroll.ScrollBarImageColor3 = Color3.fromRGB(80, 80, 80)
	tagsScroll.CanvasSize = UDim2.new(0, 0, 0, 0)
	tagsScroll.AutomaticCanvasSize = Enum.AutomaticSize.X
	tagsScroll.ScrollingDirection = Enum.ScrollingDirection.Horizontal
	tagsScroll.Parent = c

	local tagLayout = Instance.new("UIListLayout")
	tagLayout.FillDirection = Enum.FillDirection.Horizontal
	tagLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tagLayout.Padding = UDim.new(0, 6)
	tagLayout.VerticalAlignment = Enum.VerticalAlignment.Center
	tagLayout.Parent = tagsScroll

	local currentSuggestion = ""

	local function refreshTags()
		for _, child in ipairs(tagsScroll:GetChildren()) do
			if child:IsA("GuiObject") then
				child:Destroy()
			end
		end

		if #Settings.Exclusions == 0 then
			local emptyLabel = Instance.new("TextLabel")
			emptyLabel.Size = UDim2.new(1, 0, 1, 0)
			emptyLabel.BackgroundTransparency = 1
			emptyLabel.Text = "No exclusions"
			emptyLabel.TextColor3 = Color3.fromRGB(100, 100, 100)
			emptyLabel.Font = Enum.Font.GothamMedium
			emptyLabel.TextSize = 12
			emptyLabel.TextXAlignment = Enum.TextXAlignment.Left
			emptyLabel.Parent = tagsScroll
			return
		end

		for _, name in ipairs(Settings.Exclusions) do
			local tag = Instance.new("TextButton")
			tag.Size = UDim2.new(0, 0, 0, 20)
			tag.AutomaticSize = Enum.AutomaticSize.X
			tag.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
			tag.Text = "  " .. name .. "  "
			tag.TextColor3 = Color3.fromRGB(180, 180, 180)
			tag.Font = Enum.Font.GothamMedium
			tag.TextSize = 11
			tag.AutoButtonColor = false
			tag.Parent = tagsScroll

			Instance.new("UICorner", tag).CornerRadius = UDim.new(0, 4)
			local tStroke = Instance.new("UIStroke")
			tStroke.Color = Color3.fromRGB(50, 50, 50)
			tStroke.Thickness = 1
			tStroke.Parent = tag

			tag.MouseEnter:Connect(function()
				TweenService:Create(tag, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(255, 75, 75), BackgroundColor3 = Color3.fromRGB(30, 10, 10)}):Play()
				TweenService:Create(tStroke, TweenInfo.new(0.12), {Color = Color3.fromRGB(200, 50, 50)}):Play()
			end)

			tag.MouseLeave:Connect(function()
				TweenService:Create(tag, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(180, 180, 180), BackgroundColor3 = Color3.fromRGB(15, 15, 15)}):Play()
				TweenService:Create(tStroke, TweenInfo.new(0.12), {Color = Color3.fromRGB(50, 50, 50)}):Play()
			end)

			tag.MouseButton1Click:Connect(function()
				for i, v in ipairs(Settings.Exclusions) do
					if v == name then
						table.remove(Settings.Exclusions, i)
						break
					end
				end
				refreshTags()
			end)
		end
	end
	refreshTags()

	-- Autocomplete matching logic
	box:GetPropertyChangedSignal("Text"):Connect(function()
		local text = box.Text
		if text == "" then
			ghostLabel.Text = ""
			currentSuggestion = ""
			return
		end

		local match = nil
		for _, player in ipairs(Players:GetPlayers()) do
			if player.Name:lower():sub(1, #text) == text:lower() then
				match = player.Name
				break
			end
		end

		if match and match ~= text then
			currentSuggestion = match
			ghostLabel.Text = text .. match:sub(#text + 1)
		else
			ghostLabel.Text = ""
			currentSuggestion = ""
		end
	end)

	box.FocusLost:Connect(function(enterPressed)
		if enterPressed then
			if currentSuggestion ~= "" and box.Text ~= currentSuggestion then
				box.Text = currentSuggestion
				ghostLabel.Text = ""
				currentSuggestion = ""
			else
				local name = box.Text:gsub("^%s+", ""):gsub("%s+$", "")
				if #name > 0 then
					for _, v in ipairs(Settings.Exclusions) do if v:lower() == name:lower() then return end end
					table.insert(Settings.Exclusions, name)
					box.Text = ""; refreshTags()
					task.spawn(function() abs.Color = Color3.fromRGB(255,255,255); task.wait(0.1); abs.Color = Color3.fromRGB(60,60,60) end)
				end
			end
		end
	end)

	addBtn.MouseButton1Click:Connect(function()
		local name = box.Text:gsub("^%s+", ""):gsub("%s+$", "")
		if #name > 0 then
			for _, v in ipairs(Settings.Exclusions) do if v:lower() == name:lower() then return end end
			table.insert(Settings.Exclusions, name)
			box.Text = ""; refreshTags()
			task.spawn(function() abs.Color = Color3.fromRGB(255,255,255); task.wait(0.1); abs.Color = Color3.fromRGB(60,60,60) end)
		end
	end)

	addBtn.MouseEnter:Connect(function() TweenService:Create(abs, TweenInfo.new(0.1), {Color = Color3.fromRGB(150,150,150)}):Play() end)
	addBtn.MouseLeave:Connect(function() TweenService:Create(abs, TweenInfo.new(0.1), {Color = Color3.fromRGB(60,60,60)}):Play() end)
end
end

