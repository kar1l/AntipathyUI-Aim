-- ═══════════════════════════════════════════════════════════════
-- UI ENHANCEMENT: SECTION HOVER GLITCH EFFECT
-- ═══════════════════════════════════════════════════════════════
do
	local function applySectionHoverGlitch(section)
		if not section or not section:IsA("Frame") then return end
		local glowStroke = Instance.new("UIStroke")
		glowStroke.Name = "HoverGlow"
		glowStroke.Color = Color3.fromRGB(255, 255, 255)
		glowStroke.Thickness = 1.5
		glowStroke.Transparency = 1
		glowStroke.ApplyStrokeMode = Enum.ApplyStrokeMode.Border
		glowStroke.Parent = section

		local glitchActive = false
		local glitchConn = nil
		local updateTimer = 0
		local targetColor = Color3.fromRGB(255, 255, 255)
		local targetTransparency = 0.3
		local targetThickness = 1.5

		section.MouseEnter:Connect(function()
			glitchActive = true
			glowStroke.Transparency = 0.3
			if glitchConn then return end
			updateTimer = 0
			glitchConn = RunService.Heartbeat:Connect(function(dt)
				if not glitchActive then
					glowStroke.Transparency = 1
					if glitchConn then glitchConn:Disconnect(); glitchConn = nil end
					return
				end
				
				updateTimer = updateTimer - dt
				if updateTimer <= 0 then
					updateTimer = 0.2 + math.random() * 0.2
					targetColor = Color3.fromRGB(math.random(100, 255), math.random(100, 255), math.random(100, 255))
					targetTransparency = 0.25 + math.random() * 0.25
					targetThickness = 1 + math.random() * 1.2
				end

				-- Smoothly interpolate towards the targets for a slower, high-end hover effect
				glowStroke.Color = glowStroke.Color:Lerp(targetColor, dt * 5)
				glowStroke.Transparency = glowStroke.Transparency + (targetTransparency - glowStroke.Transparency) * dt * 5
				glowStroke.Thickness = glowStroke.Thickness + (targetThickness - glowStroke.Thickness) * dt * 5
			end)
		end)
		section.MouseLeave:Connect(function()
			glitchActive = false
		end)
	end

	-- Apply to all existing sections in each tab
	task.defer(function()
		task.wait(0.1)
		for _, tab in ipairs({aimTab, visTab, rageTab}) do
			for _, child in ipairs(tab:GetChildren()) do
				if child:IsA("Frame") and child.BackgroundTransparency < 1 and child:FindFirstChild("Settings") then
					applySectionHoverGlitch(child)
				end
			end
		end
	end)
end

-- ═══════════════════════════════════════════════════════════════
-- UI ENHANCEMENT: BUTTERFLY PARTICLE SYSTEM
-- ═══════════════════════════════════════════════════════════════
do
	local NUM_BUTTERFLIES = 14
	local butterflies = {}

	local bgContainer = Instance.new("CanvasGroup")
	bgContainer.Name = "BgContainer"
	bgContainer.Size = UDim2.new(1, -110, 1, -32 - 24)
	bgContainer.Position = UDim2.new(0, 0, 0, 32)
	bgContainer.BackgroundTransparency = 1
	bgContainer.ZIndex = 1
	bgContainer.Parent = frame

	for i = 1, NUM_BUTTERFLIES do
		-- Create butterfly body with two wing frames
		local body = Instance.new("Frame")
		body.Size = UDim2.new(0, 2, 0, 6)
		body.BackgroundColor3 = Color3.fromRGB(math.random(180, 255), math.random(180, 255), math.random(180, 255))
		body.BackgroundTransparency = math.random(50, 75) / 100
		body.BorderSizePixel = 0
		body.ZIndex = 3
		body.Rotation = math.random(-30, 30)
		body.Position = UDim2.new(math.random() * 0.9, 0, math.random() * 0.85 + 0.08, 0)
		body.Parent = bgContainer

		local wingL = Instance.new("Frame")
		wingL.Size = UDim2.new(0, 5, 0, 3)
		wingL.Position = UDim2.new(0, -5, 0.5, -1)
		wingL.BackgroundColor3 = body.BackgroundColor3
		wingL.BackgroundTransparency = body.BackgroundTransparency - 0.1
		wingL.BorderSizePixel = 0
		wingL.ZIndex = 3
		Instance.new("UICorner", wingL).CornerRadius = UDim.new(0, 2)
		wingL.Parent = body

		local wingR = Instance.new("Frame")
		wingR.Size = UDim2.new(0, 5, 0, 3)
		wingR.Position = UDim2.new(1, 0, 0.5, -1)
		wingR.BackgroundColor3 = body.BackgroundColor3
		wingR.BackgroundTransparency = body.BackgroundTransparency - 0.1
		wingR.BorderSizePixel = 0
		wingR.ZIndex = 3
		Instance.new("UICorner", wingR).CornerRadius = UDim.new(0, 2)
		wingR.Parent = body

		table.insert(butterflies, {
			body = body,
			wingL = wingL,
			wingR = wingR,
			x = body.Position.X.Scale,
			y = body.Position.Y.Scale,
			vx = (math.random() - 0.5) * 0.04,
			vy = (math.random() - 0.5) * 0.02,
			phase = math.random() * math.pi * 2,
			wingPhase = math.random() * math.pi * 2,
			flutterSpeed = 2.0 + math.random() * 2.0,
			dirChangeTimer = math.random() * 4,
		})
	end

	task.spawn(function()
		while frame.Parent do
			local dt = RunService.Heartbeat:Wait()
			for _, bf in ipairs(butterflies) do
				bf.phase = bf.phase + dt * 0.8
				bf.wingPhase = bf.wingPhase + dt * bf.flutterSpeed
				bf.dirChangeTimer = bf.dirChangeTimer - dt

				-- Change direction randomly (very gentle butterfly flutter)
				if bf.dirChangeTimer <= 0 then
					bf.vx = (math.random() - 0.5) * 0.05
					bf.vy = (math.random() - 0.5) * 0.025
					bf.dirChangeTimer = 1.0 + math.random() * 3.0
				end

				-- Figure-8 flutter path overlay (adds natural swaying oscillation)
				local flutterX = math.sin(bf.phase * 1.5) * 0.006
				local flutterY = math.sin(bf.phase * 2.5) * math.cos(bf.phase * 0.8) * 0.004

				-- Update base coordinates linearly using velocity
				bf.x = bf.x + bf.vx * dt
				bf.y = bf.y + bf.vy * dt

				-- Bounce around (within bgContainer)
				if bf.x > 0.98 then 
					bf.x = 0.98; bf.vx = -math.abs(bf.vx) 
				elseif bf.x < 0.02 then 
					bf.x = 0.02; bf.vx = math.abs(bf.vx) 
				end
				if bf.y > 0.98 then 
					bf.y = 0.98; bf.vy = -math.abs(bf.vy) 
				elseif bf.y < 0.02 then 
					bf.y = 0.02; bf.vy = math.abs(bf.vy) 
				end

				-- Visual position includes the non-cumulative figure-8 flutter overlay
				bf.body.Position = UDim2.new(bf.x + flutterX, 0, bf.y + flutterY, 0)
				bf.body.Rotation = math.sin(bf.phase * 1.5) * 20

				-- Wing flap animation (natural slow size oscillation)
				local wingFlap = math.abs(math.sin(bf.wingPhase))
				local wingH = math.floor(2 + wingFlap * 6)
				bf.wingL.Size = UDim2.new(0, 6, 0, wingH)
				bf.wingR.Size = UDim2.new(0, 6, 0, wingH)
				bf.wingL.Position = UDim2.new(0, -6, 0.5, -wingH/2)
				bf.wingR.Position = UDim2.new(1, 0, 0.5, -wingH/2)
				bf.body.BackgroundTransparency = 0.55 + math.sin(bf.phase * 1.8) * 0.2
			end
		end
	end)

	local _activeStars = 0
	local _maxStars = 5
	task.spawn(function()
		while frame.Parent do
			if _activeStars >= _maxStars then task.wait(1) continue end
			_activeStars = _activeStars + 1
			local star = Instance.new("Frame")
			star.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			star.BorderSizePixel = 0
			star.ZIndex = 2
			local startX = math.random() > 0.5 and 1.1 or -0.1
			local startY = math.random() * 1.2 - 0.1
			star.Position = UDim2.new(startX, 0, startY, 0)
			
			star.Size = UDim2.new(0, math.random(20, 60), 0, 1)
			local angle = math.rad(math.random(-20, 20))
			local distance = 1.5
			local dir = startX > 0.5 and -1 or 1
			local endX = startX + math.cos(angle) * distance * dir
			local endY = startY + math.sin(angle) * distance * dir
			
			local absW = bgContainer.AbsoluteSize.X > 0 and bgContainer.AbsoluteSize.X or 500
			local absH = bgContainer.AbsoluteSize.Y > 0 and bgContainer.AbsoluteSize.Y or 300
			star.Rotation = math.deg(math.atan2((endY - startY)*absH, (endX - startX)*absW))
			
			local grad = Instance.new("UIGradient")
			grad.Color = ColorSequence.new{ColorSequenceKeypoint.new(0, Color3.fromRGB(255,255,255)), ColorSequenceKeypoint.new(1, Color3.fromRGB(255,255,255))}
			grad.Transparency = NumberSequence.new{NumberSequenceKeypoint.new(0, 1), NumberSequenceKeypoint.new(1, 0)}
			grad.Parent = star

			local sparkle = Instance.new("Frame")
			sparkle.Size = UDim2.new(0, 3, 0, 3)
			sparkle.Position = UDim2.new(1, 0, 0.5, 0)
			sparkle.AnchorPoint = Vector2.new(0.5, 0.5)
			sparkle.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
			sparkle.BorderSizePixel = 0
			sparkle.ZIndex = 2
			Instance.new("UICorner", sparkle).CornerRadius = UDim.new(1, 0)
			sparkle.Parent = star
			
			star.Parent = bgContainer
			
			local tweenDur = math.random(10, 20)/10
			local tInfo = TweenInfo.new(tweenDur, Enum.EasingStyle.Linear)
			local tween = TweenService:Create(star, tInfo, {Position = UDim2.new(endX, 0, endY, 0)})
			tween:Play()
			tween.Completed:Connect(function() star:Destroy(); _activeStars = _activeStars - 1 end)
			
			task.wait(math.random(1, 4))
		end
	end)
end

-- ═══════════════════════════════════════════════════════════════
-- UI ENHANCEMENT: STATUS BAR
-- ═══════════════════════════════════════════════════════════════
local statusBar
local STATUS_H = 24
local _sessionStartTime = tick()
do
	statusBar = Instance.new("Frame")
	statusBar.Name = "StatusBar"
	statusBar.Size = UDim2.new(1, -TAB_PANEL_W, 0, STATUS_H)
	statusBar.Position = UDim2.new(0, 0, 1, -STATUS_H)
	statusBar.AutomaticSize = Enum.AutomaticSize.None
	statusBar.BackgroundColor3 = Color3.fromRGB(8, 8, 8)
	statusBar.BorderSizePixel = 0
	statusBar.ZIndex = 60
	statusBar.Parent = frame

	local sbPad = Instance.new("UIPadding")
	sbPad.PaddingLeft = UDim.new(0, 8)
	sbPad.PaddingRight = UDim.new(0, 8)
	sbPad.Parent = statusBar

	local sbDragging = false
	local sbDragStart, sbStartPos
	statusBar.InputBegan:Connect(function(input)
		if statusBar.Parent ~= frame and input.UserInputType == Enum.UserInputType.MouseButton1 then
			sbDragging = true
			sbDragStart = input.Position
			sbStartPos = statusBar.Position
		end
	end)
	statusBar.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 then
			sbDragging = false
		end
	end)
	UserInputService.InputChanged:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseMovement and sbDragging then
			local delta = input.Position - sbDragStart
			statusBar.Position = UDim2.new(sbStartPos.X.Scale, sbStartPos.X.Offset + delta.X, sbStartPos.Y.Scale, sbStartPos.Y.Offset + delta.Y)
		end
	end)

	local statusGrad = Instance.new("UIGradient")
	statusGrad.Color = ColorSequence.new{
		ColorSequenceKeypoint.new(0, Color3.fromRGB(12, 12, 12)),
		ColorSequenceKeypoint.new(1, Color3.fromRGB(5, 5, 5))
	}
	statusGrad.Parent = statusBar

	local statusSep = Instance.new("Frame")
	statusSep.Size = UDim2.new(1, 0, 0, 1)
	statusSep.Position = UDim2.new(0, 0, 0, 0)
	statusSep.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
	statusSep.BorderSizePixel = 0
	statusSep.ZIndex = 61
	statusSep.Parent = statusBar

	local statusLabel = Instance.new("TextLabel")
	statusLabel.Name = "StatusLabel"
	statusLabel.BackgroundTransparency = 1
	statusLabel.Size = UDim2.new(1, 0, 1, 0)
	statusLabel.Position = UDim2.new(0, 0, 0, 0)
	statusLabel.AutomaticSize = Enum.AutomaticSize.None
	statusLabel.TextWrapped = false
	statusLabel.Text = "FPS: -- | Ping: -- | Players: -- | Session: 0:00 | Active: 0"
	statusLabel.TextColor3 = Color3.fromRGB(140, 140, 140)
	statusLabel.Font = Enum.Font.Code
	statusLabel.TextSize = 12
	statusLabel.TextXAlignment = Enum.TextXAlignment.Center
	statusLabel.ZIndex = 62
	statusLabel.Parent = statusBar

	local frameCount = 0
	local lastFPSUpdate = tick()
	local statusGlitch = {"FPS", "F?S", "FP$", "??S"}

	task.spawn(function()
		while statusBar.Parent do
			frameCount = frameCount + 1
			local now = tick()
			if now - lastFPSUpdate >= 0.5 then
				local fps = math.floor(frameCount / (now - lastFPSUpdate))
				frameCount = 0
				lastFPSUpdate = now

				local fpsText = "FPS: " .. fps
				if math.random(1, 8) == 1 then
					fpsText = statusGlitch[math.random(#statusGlitch)] .. ": " .. fps
				end

				-- Ping
				local ping = "--"
				pcall(function()
					local stats = game:GetService("Stats")
					local success, val = pcall(function() return stats.Network.ServerStatsItem["Data Ping"]:GetValue() end)
					if not success then
						val = stats.PerformanceStats.Ping:GetValue()
					end
					ping = tostring(math.floor(val))
				end)

				-- Session time
				local elapsed = math.floor(now - _sessionStartTime)
				local hrs = math.floor(elapsed / 3600)
				local mins = math.floor((elapsed % 3600) / 60)
				local secs = elapsed % 60
				local sessionStr = hrs > 0 and string.format("%d:%02d:%02d", hrs, mins, secs) or string.format("%d:%02d", mins, secs)

