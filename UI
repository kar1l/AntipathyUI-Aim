	local active = showAim and aimTab or visTab
	local inactive = showAim and visTab or aimTab
	for _, ch in ipairs(inactive:GetChildren()) do if ch:IsA("GuiObject") then ch.Visible = true end end
	inactive.Visible = false
	active.Visible = true
	for _, ch in ipairs(active:GetChildren()) do
		if ch:IsA("GuiObject") then
			local ot = ch.BackgroundTransparency
			if ot < 1 then ch.BackgroundTransparency = 1; TweenService:Create(ch, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = ot}):Play() end
			if ch:IsA("TextLabel") or ch:IsA("TextBox") or ch:IsA("TextButton") then
				local tt = ch.TextTransparency; ch.TextTransparency = 1
				TweenService:Create(ch, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = tt}):Play()
			end
		end
	end
	aimTabBtn:SetAttribute("IsActiveTab", showAim); visTabBtn:SetAttribute("IsActiveTab", not showAim)
	-- Update tab visuals
	local function updateTab(btn, isActive)
		local c = isActive and Color3.fromRGB(255,255,255) or Color3.fromRGB(100,100,100)
		local icon = btn:FindFirstChild("Icon")
		local label = btn:FindFirstChild("Label")
		if icon then TweenService:Create(icon, TweenInfo.new(0.15), {TextColor3 = c}):Play() end
		if label then TweenService:Create(label, TweenInfo.new(0.15), {TextColor3 = c}):Play() end
		local img = btn:FindFirstChild("TabImage")
		if img then TweenService:Create(img, TweenInfo.new(0.15), {ImageTransparency = isActive and 0.7 or 0.9}):Play() end
	end
	updateTab(aimTabBtn, showAim); updateTab(visTabBtn, not showAim)
	TweenService:Create(aimTabLine, TweenInfo.new(0.15), {BackgroundColor3 = showAim and Color3.fromRGB(255,255,255) or Color3.fromRGB(70,70,70)}):Play()
	TweenService:Create(visTabLine, TweenInfo.new(0.15), {BackgroundColor3 = showAim and Color3.fromRGB(70,70,70) or Color3.fromRGB(255,255,255)}):Play()
	aimTabStroke.Transparency = showAim and 0.3 or 1; visTabStroke.Transparency = showAim and 1 or 0.3
end

aimTabBtn.MouseButton1Click:Connect(function() switchTab(true) end)
visTabBtn.MouseButton1Click:Connect(function() switchTab(false) end)

