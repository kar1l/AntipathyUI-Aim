local bdx, bdy = 1, 1
local bspeed = 0.1
local bfx, bfy = 0, 0
local blt = 0
task.spawn(function()
	while bgFooter.Parent do
		local fs = frame.AbsoluteSize
		local ts = bgFooter.AbsoluteSize
		if fs.X == 0 or ts.X == 0 then RunService.Heartbeat:Wait() continue end
		local mx, my = fs.X - ts.X, fs.Y - ts.Y
		bfx = bfx + bspeed * bdx; bfy = bfy + bspeed * bdy
		local hit = false
		if bfx >= mx then bfx = mx; bdx = -1; hit = true elseif bfx <= 0 then bfx = 0; bdx = 1; hit = true end
		if bfy >= my then bfy = my; bdy = -1; hit = true elseif bfy <= 0 then bfy = 0; bdy = 1; hit = true end
		if hit then bgFooter.TextColor3 = Color3.fromRGB(math.random(150,255), math.random(150,255), math.random(150,255)) end
		local now = tick()
		if now - blt > 0.03 then
			blt = now
			local g = bgFooter:Clone()
			g.TextColor3 = Color3.fromRGB(255,255,255); g.TextTransparency = 0.6; g.ZIndex = 2; g.TextSize = bgFooter.TextSize + 1; g.Parent = frame
			task.spawn(function() for i=1,10 do g.TextTransparency += 0.04; task.wait(0.02) end g:Destroy() end)
		end
		bgFooter.Position = UDim2.new(0, math.floor(bfx), 0, math.floor(bfy))
		RunService.Heartbeat:Wait()
	end
end)

