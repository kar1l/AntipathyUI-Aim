minimizeBtn.MouseButton1Click:Connect(function()
	dragging = false; targetPos = nil
	if isMinimized then
		isMinimized = false
		for _, ht in ipairs(halftones) do ht.Visible = true end
		task.spawn(function()
			body.Visible = true; frame.Size = UDim2.new(0, FRAME_W, 0, FRAME_H)
			local s = deviceScale; local op = frame.Position
			for _=1,5 do uiScale.Scale = s*(0.8+math.random()*0.4); frame.Position = op + UDim2.new(0, math.random(-20,20), 0, math.random(-20,20)); frame.BackgroundTransparency = math.random()*0.5; task.wait(0.03+math.random()*0.04) end
			uiScale.Scale = s; frame.Position = op; frame.BackgroundTransparency = 0
		end)
	else
		isMinimized = true
		for _, ht in ipairs(halftones) do ht.Visible = false end
		task.spawn(function()
			local s = deviceScale; local op = frame.Position
			for _=1,5 do uiScale.Scale = s*(0.7+math.random()*0.3); frame.Position = op + UDim2.new(0, math.random(-15,15), 0, math.random(-15,15)); frame.BackgroundTransparency = math.random()*0.3; task.wait(0.03+math.random()*0.04) end
			uiScale.Scale = s; frame.Position = op; frame.BackgroundTransparency = 0
			-- Minimized: just title bar height
			frame.Size = UDim2.new(0, FRAME_W, 0, TOPBAR_H); body.Visible = false
		end)
	end
end)

closeBtn.MouseButton1Click:Connect(function()
	dragging = false; targetPos = nil
	task.spawn(function()
		local vp = workspace.CurrentCamera.ViewportSize
		local tp = {UDim2.new(0,80,0,80), UDim2.new(0,vp.X-500,0,vp.Y-200), UDim2.new(0,120,0,vp.Y-380), UDim2.new(0,vp.X-470,0,100), UDim2.new(0.5,-FRAME_W/2,0.5,-FRAME_H/2), UDim2.new(0.5,200,0.3,0)}
		for _, pos in ipairs(tp) do frame.Position = pos; uiScale.Scale = deviceScale*(0.6+math.random()*0.4); frame.BackgroundTransparency = math.random()*0.3; task.wait(0.06) end
