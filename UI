			local ap = sliderBg.AbsolutePosition.X; local as = sliderBg.AbsoluteSize.X
			if as == 0 then return end
			updateVal(math.clamp((input.Position.X - ap) / as, 0, 1) * maxVal)
		end
	end)
	UserInputService.InputEnded:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton1 and sliding then sliding = false end
	end)

	return { GetValue = function() return val end, SetValue = function(nv) updateVal(nv) end }
end

