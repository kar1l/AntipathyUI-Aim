-- TAB SWITCHING (3 tabs)
-- ═══════════════════════════════════════════════════════════════
local function switchTab(tabName)
	local tabs = {Aim = aimTab, Visuals = visTab, Rage = rageTab, Frame = frameTab, Misc = miscTab, Settings = settingsTab}
	local buttons = {Aim = aimTabBtn, Visuals = visTabBtn, Rage = rageTabBtn, Frame = frameTabBtn, Misc = miscTabBtn, Settings = settingsTabBtn}
	local tabLines = {Aim = aimTabLine, Visuals = visTabLine, Rage = rageTabLine, Frame = frameTabLine, Misc = miscTabLine, Settings = settingsTabLine}
	local tabStrokes = {Aim = aimTabStroke, Visuals = visTabStroke, Rage = rageTabStroke, Frame = frameTabStroke, Misc = miscTabStroke, Settings = settingsTabStroke}

	for name, tab in pairs(tabs) do
		local isActive = (name == tabName)
		if not isActive then
			tab.Visible = false
		end
	end

	local activeTab = tabs[tabName]
	activeTab.Visible = true
	for _, ch in ipairs(activeTab:GetChildren()) do
		if ch:IsA("GuiObject") then
			local ot = ch.BackgroundTransparency
			if ot < 1 then ch.BackgroundTransparency = 1; TweenService:Create(ch, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {BackgroundTransparency = ot}):Play() end
			if ch:IsA("TextLabel") or ch:IsA("TextBox") or ch:IsA("TextButton") then
				local tt = ch.TextTransparency; ch.TextTransparency = 1
				TweenService:Create(ch, TweenInfo.new(0.2, Enum.EasingStyle.Quad, Enum.EasingDirection.Out), {TextTransparency = tt}):Play()
			end
		end
	end

	for name, btn in pairs(buttons) do
		local isActive = (name == tabName)
		btn:SetAttribute("IsActiveTab", isActive)
		local c = isActive and Color3.fromRGB(255,255,255) or Color3.fromRGB(100,100,100)
		local icon = btn:FindFirstChild("Icon")
		local label = btn:FindFirstChild("Label")
		if icon then TweenService:Create(icon, TweenInfo.new(0.15), {TextColor3 = c}):Play() end
		if label then TweenService:Create(label, TweenInfo.new(0.15), {TextColor3 = c}):Play() end
		local img = btn:FindFirstChild("TabImage")
		if img then TweenService:Create(img, TweenInfo.new(0.15), {ImageTransparency = isActive and 0 or 0.7}):Play() end
		
		-- Update CornerLine colors
		local cornerCol = isActive and Color3.fromRGB(120, 120, 120) or Color3.fromRGB(50, 50, 50)
		for _, child in ipairs(btn:GetChildren()) do
			if child.Name == "CornerLine" then
				TweenService:Create(child, TweenInfo.new(0.15), {BackgroundColor3 = cornerCol}):Play()
			end
		end

		TweenService:Create(tabLines[name], TweenInfo.new(0.15), {BackgroundColor3 = isActive and Color3.fromRGB(255,255,255) or Color3.fromRGB(70,70,70)}):Play()
		tabStrokes[name].Transparency = isActive and 0.3 or 1
	end
end

