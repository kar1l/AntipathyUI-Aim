			tag.TextColor3 = Color3.fromRGB(170,170,170)
			tag.AutoButtonColor = false; tag.ZIndex = 11; tag.LayoutOrder = idx; tag.Parent = tagsFrame

			-- Corner-style border instead of full outline
			addCornerBorder(tag, Color3.fromRGB(60,60,60), 1, 6)

			tag.MouseEnter:Connect(function()
				TweenService:Create(tag, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(255,80,80), BackgroundColor3 = Color3.fromRGB(35,10,10)}):Play()
				tag.Text = name.." ✕"
			end)
			tag.MouseLeave:Connect(function()
				TweenService:Create(tag, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(170,170,170), BackgroundColor3 = Color3.fromRGB(12,12,12)}):Play()
				tag.Text = name
			end)
			tag.MouseButton1Click:Connect(function()
				for i, v in ipairs(Settings.Exclusions) do if v == name then table.remove(Settings.Exclusions, i); break end end
				refreshTags()
			end)
		end
	end
	refreshTags()

	local function findSuggestion(partial)
		if #partial == 0 then return nil end
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer then
				if player.Name:lower():sub(1, #partial) == partial:lower() then return player.Name end
				if player.DisplayName:lower():sub(1, #partial) == partial:lower() then return player.DisplayName end
			end
		end
		return nil
	end

	box:GetPropertyChangedSignal("Text"):Connect(function()
		local typed = box.Text
		if #typed > 0 then
			local suggestion = findSuggestion(typed)
			if suggestion then ghostLabel.Text = suggestion; currentSuggestion = suggestion
			else ghostLabel.Text = ""; currentSuggestion = nil end
		else ghostLabel.Text = ""; currentSuggestion = nil end
	end)

	local function addExclusion()
		local name = box.Text:gsub("^%s+",""):gsub("%s+$","")
		if #name == 0 and currentSuggestion then name = currentSuggestion end
		if #name > 0 then
			for _, v in ipairs(Settings.Exclusions) do if v:lower() == name:lower() then return end end
			table.insert(Settings.Exclusions, name)
			box.Text = ""; ghostLabel.Text = ""; currentSuggestion = nil; refreshTags()
			task.spawn(function() abs.Color = Color3.fromRGB(255,255,255); task.wait(0.1); abs.Color = Color3.fromRGB(55,55,55) end)
		end
	end

	addBtn.MouseButton1Click:Connect(addExclusion)
	addBtn.MouseEnter:Connect(function() TweenService:Create(abs, TweenInfo.new(0.1), {Color = Color3.fromRGB(140,140,140)}):Play() end)
	addBtn.MouseLeave:Connect(function() TweenService:Create(abs, TweenInfo.new(0.1), {Color = Color3.fromRGB(55,55,55)}):Play() end)

	box.FocusLost:Connect(function(enterPressed)
		if enterPressed then
			if currentSuggestion and #box.Text > 0 then
				box.Text = currentSuggestion; ghostLabel.Text = ""
				task.wait(0.05); addExclusion()
			elseif #box.Text:gsub("%s","") > 0 then addExclusion() end
		end
	end)
end

