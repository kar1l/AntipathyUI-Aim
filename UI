-- Exclusion Manager (Fix ghost letters exact overlap)
local function createExclusionManager(order, parent)
	local c = Instance.new("Frame"); c.LayoutOrder = order; c.Size = UDim2.new(1, 0, 0, 90); c.BackgroundTransparency = 1; c.Parent = parent
	local lb = Instance.new("TextLabel"); lb.BackgroundTransparency = 1; lb.Size = UDim2.new(1, 0, 0, 16); lb.Text = "Exclusions (won't target these players)"; lb.TextColor3 = Color3.fromRGB(180,180,180); lb.Font = Enum.Font.GothamMedium; lb.TextSize = 13; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.Parent = c

	local row = Instance.new("Frame"); row.Size = UDim2.new(1, 0, 0, 26); row.Position = UDim2.new(0, 0, 0, 20); row.BackgroundTransparency = 1; row.Parent = c
	local boxCont = Instance.new("Frame"); boxCont.Size = UDim2.new(1, -60, 1, 0); boxCont.BackgroundColor3=Color3.fromRGB(10,10,10); boxCont.Parent = row
	Instance.new("UICorner", boxCont).CornerRadius = UDim.new(0, 6)
	Instance.new("UIStroke", boxCont).Color = Color3.fromRGB(60,60,60)

	-- Ghost label is UNDER the invisible textbox text so it perfectly overlaps
	local ghost = Instance.new("TextLabel"); ghost.Size = UDim2.new(1, 0, 1, 0); ghost.BackgroundTransparency = 1; ghost.Text = ""; ghost.Font = Enum.Font.GothamMedium; ghost.TextSize = 13; ghost.TextColor3 = Color3.fromRGB(80, 80, 80); ghost.TextXAlignment = Enum.TextXAlignment.Left; ghost.ZIndex = 11; ghost.Parent = boxCont
	Instance.new("UIPadding", ghost).PaddingLeft = UDim.new(0, 8)

	local box = Instance.new("TextBox"); box.Size = UDim2.new(1, 0, 1, 0); box.BackgroundTransparency = 1; box.PlaceholderText = "Player name..."; box.PlaceholderColor3 = Color3.fromRGB(80,80,80); box.Text = ""; box.Font = Enum.Font.GothamMedium; box.TextSize = 13; box.TextColor3 = Color3.fromRGB(255,255,255); box.ClearTextOnFocus = false; box.TextXAlignment = Enum.TextXAlignment.Left; box.ZIndex = 12; box.Parent = boxCont
	Instance.new("UIPadding", box).PaddingLeft = UDim.new(0, 8)

	local addBtn = Instance.new("TextButton"); addBtn.Size = UDim2.new(0, 52, 1, 0); addBtn.Position = UDim2.new(1, -52, 0, 0); addBtn.BackgroundColor3 = Color3.fromRGB(10,10,10); addBtn.Text = "+ Add"; addBtn.Font = Enum.Font.GothamBold; addBtn.TextSize = 12; addBtn.TextColor3 = Color3.fromRGB(200,200,200); addBtn.Parent = row
	Instance.new("UICorner", addBtn).CornerRadius = UDim.new(0, 6)
	Instance.new("UIStroke", addBtn).Color = Color3.fromRGB(60,60,60)

	local tags = Instance.new("Frame"); tags.Size = UDim2.new(1, 0, 0, 40); tags.Position = UDim2.new(0, 0, 0, 50); tags.BackgroundTransparency = 1; tags.Parent = c
	local tl = Instance.new("UIListLayout"); tl.FillDirection = Enum.FillDirection.Horizontal; tl.Padding = UDim.new(0, 6); tl.Wraps = true; tl.Parent = tags

	local function refresh()
		for _, ch in ipairs(tags:GetChildren()) do if ch:IsA("TextButton") or ch.Name == "NoTag" then ch:Destroy() end end
		if #Settings.Exclusions == 0 then
			local no = Instance.new("TextLabel"); no.BackgroundTransparency=1; no.Size=UDim2.new(1,0,0,16); no.Text="No exclusions"; no.TextColor3=Color3.fromRGB(80,80,80); no.Font=Enum.Font.Code; no.TextSize=12; no.TextXAlignment=Enum.TextXAlignment.Left; no.Name="NoTag"; no.Parent=tags
			return
		end
		for i, name in ipairs(Settings.Exclusions) do
			local tag = Instance.new("TextButton"); tag.Size = UDim2.new(0, #name * 8 + 24, 0, 20); tag.BackgroundColor3 = Color3.fromRGB(20,20,20); tag.Text = name; tag.Font = Enum.Font.Code; tag.TextSize = 12; tag.TextColor3 = Color3.fromRGB(180,180,180); tag.Parent = tags
			Instance.new("UICorner", tag).CornerRadius = UDim.new(0, 5)
			local ts = Instance.new("UIStroke", tag); ts.Color = Color3.fromRGB(60,60,60)
			tag.MouseEnter:Connect(function() tag.TextColor3=Color3.fromRGB(255,80,80); tag.BackgroundColor3=Color3.fromRGB(40,10,10); tag.Text=name.." ✕"; ts.Color=Color3.fromRGB(200,60,60) end)
			tag.MouseLeave:Connect(function() tag.TextColor3=Color3.fromRGB(180,180,180); tag.BackgroundColor3=Color3.fromRGB(20,20,20); tag.Text=name; ts.Color=Color3.fromRGB(60,60,60) end)
			tag.MouseButton1Click:Connect(function() table.remove(Settings.Exclusions, i); refresh() end)
		end
	end
	refresh()

	local curSug = nil
	box:GetPropertyChangedSignal("Text"):Connect(function()
		local t = box.Text
		if #t > 0 then
			local low = t:lower()
			curSug = nil
			for _, p in ipairs(Players:GetPlayers()) do
				if p ~= LocalPlayer and (p.Name:lower():sub(1,#low)==low or p.DisplayName:lower():sub(1,#low)==low) then
					curSug = p.Name:lower():sub(1,#low)==low and p.Name or p.DisplayName
					break
				end
			end
			-- Because fonts are identical and box text is white, the ghost gray text will perfectly overlap!
			if curSug then ghost.Text = curSug else ghost.Text = "" end
		else
			ghost.Text = ""; curSug = nil
		end
	end)

	local function add()
		local name = box.Text:gsub("^%s+",""):gsub("%s+$","")
		if #name == 0 and curSug then name = curSug end
		if #name > 0 then
			for _, v in ipairs(Settings.Exclusions) do if v:lower() == name:lower() then return end end
			table.insert(Settings.Exclusions, name); box.Text = ""; ghost.Text = ""; curSug = nil; refresh()
		end
	end
	addBtn.MouseButton1Click:Connect(add)
	box.FocusLost:Connect(function(enter)
		if enter then
			if curSug and #box.Text > 0 then box.Text = curSug; ghost.Text = ""; task.wait(0.05); add()
			elseif #box.Text > 0 then add() end
		end
	end)
end

