-- Click-off Dimming: dim when clicking outside UI, undim when clicking inside
local isDimmed = false
UserInputService.InputBegan:Connect(function(input)
	if input.UserInputType == Enum.UserInputType.MouseButton1 then
		local mousePos = UserInputService:GetMouseLocation()
		local guiPos = frame.AbsolutePosition
		local guiSize = frame.AbsoluteSize
		local isInside = mousePos.X >= guiPos.X and mousePos.X <= guiPos.X + guiSize.X and
		                 mousePos.Y >= guiPos.Y and mousePos.Y <= guiPos.Y + guiSize.Y
		if isInside then
			if isDimmed then
				isDimmed = false
				TweenService:Create(dimOverlay, TweenInfo.new(0.2), {BackgroundTransparency = 1}):Play()
			end
		else
			if not isDimmed then
				isDimmed = true
				TweenService:Create(dimOverlay, TweenInfo.new(0.4), {BackgroundTransparency = 0.45}):Play()
			end
		end
	end
end)

