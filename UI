local function updatePreviewAvatar(img, lbl)
	local playersList = Players:GetPlayers()
	local selectedPlayer = nil
	if #playersList > 1 then
		local list = {}
		for _, p in ipairs(playersList) do
			if p ~= LocalPlayer then
				table.insert(list, p)
			end
		end
		if #list > 0 then
			selectedPlayer = list[math.random(#list)]
		end
	end
	if not selectedPlayer then
		selectedPlayer = LocalPlayer
	end
	if selectedPlayer then
		local userId = selectedPlayer.UserId
		lbl.Text = selectedPlayer.DisplayName or selectedPlayer.Name
		img.Image = "rbxthumb://type=Avatar&id=" .. userId .. "&w=180&h=180"
	end
end

