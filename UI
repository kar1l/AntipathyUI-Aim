	cpPreview.BackgroundColor3 = initialColor
	activeCallback = function()
		local c3 = Color3.fromRGB(sliderR.GetValue(), sliderG.GetValue(), sliderB.GetValue())
		cpPreview.BackgroundColor3 = c3
		callback(c3)
	end
	pickerActive = true; cp.Visible = true
end

