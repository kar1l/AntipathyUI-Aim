local function makeTopButton(text, xOffset, colorSet)
	local btn = Instance.new("TextButton")
	btn.Size = UDim2.new(0, 32, 0, 28)
	btn.Position = UDim2.new(1, xOffset, 0.5, -14)
	btn.BackgroundColor3 = colorSet.base or Color3.fromRGB(255, 255, 255)
	btn.TextColor3 = Color3.fromRGB(0, 0, 0)
	btn.TextStrokeColor3 = Color3.fromRGB(150, 150, 150)
	btn.TextStrokeTransparency = 0.8
	btn.Font = Enum.Font.GothamBold
	btn.TextSize = 16
	btn.Text = text
	btn.ZIndex = 300
	btn.AutoButtonColor = false
	btn.Parent = topbar
	Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 8)
	local gradient
	if colorSet.gradient then
		gradient = Instance.new("UIGradient"); gradient.Color = colorSet.gradient; gradient.Rotation = 90; gradient.Parent = btn
	end
	local s = Instance.new("UIStroke"); s.Color = colorSet.stroke; s.Thickness = 2; s.Transparency = 0.1; s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border; s.Parent = btn
	btn.MouseEnter:Connect(function()
		if gradient then TweenService:Create(gradient, TweenInfo.new(0.12), {Color = colorSet.hoverGradient}):Play()
		elseif colorSet.hoverBase then TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = colorSet.hoverBase}):Play() end
		TweenService:Create(s, TweenInfo.new(0.12), {Transparency = 0}):Play()
	end)
	btn.MouseLeave:Connect(function()
		if gradient then TweenService:Create(gradient, TweenInfo.new(0.12), {Color = colorSet.gradient}):Play()
		elseif colorSet.base then TweenService:Create(btn, TweenInfo.new(0.12), {BackgroundColor3 = colorSet.base}):Play() end
		TweenService:Create(s, TweenInfo.new(0.12), {Transparency = 0.1}):Play()
	end)
	btn.MouseButton1Down:Connect(function() TweenService:Create(btn, TweenInfo.new(0.05), {Size = UDim2.new(0, 29, 0, 25)}):Play() end)
	btn.MouseButton1Up:Connect(function() TweenService:Create(btn, TweenInfo.new(0.05), {Size = UDim2.new(0, 32, 0, 28)}):Play() end)
	return btn
end

