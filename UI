-- Hex color with swatch click (picker) + double-click (rainbow)
local function createHexColor(text, order, parent, tbl, key, wScale, wOff)
	local currentHex = tbl and tbl[key] or "FFFFFF"
	local rainbowActive = false
	local rainbowConn = nil
	wScale = wScale or 1
	wOff = wOff or 0

	local c = Instance.new("Frame"); c.LayoutOrder = order; c.Size = UDim2.new(wScale, wOff, 0, 22); c.BackgroundTransparency = 1; c.ZIndex = 10; c.Parent = parent
	local lb = Instance.new("TextLabel"); lb.BackgroundTransparency = 1; lb.Size = UDim2.new(1, -105, 1, 0)
	lb.Text = text; lb.TextColor3 = Color3.fromRGB(200,200,200); lb.Font = Enum.Font.GothamMedium
	lb.TextSize = 13; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.ZIndex = 10; lb.Parent = c

	local sw = Instance.new("TextButton")
	sw.Size = UDim2.new(0, 16, 0, 16); sw.Position = UDim2.new(1, -100, 0.5, -8)
	sw.BackgroundColor3 = hexToColor3(currentHex); sw.Text = ""; sw.AutoButtonColor = false; sw.ZIndex = 11; sw.Parent = c
	Instance.new("UICorner", sw).CornerRadius = UDim.new(0, 3)
	Instance.new("UIStroke", sw).Color = Color3.fromRGB(70,70,70)

	local hb = Instance.new("TextBox")
	hb.Size = UDim2.new(0, 78, 0, 20); hb.Position = UDim2.new(1, -78, 0.5, -10)
	hb.BackgroundColor3 = Color3.fromRGB(10,10,10)
	hb.Text = ""; hb.PlaceholderText = "#"..currentHex; hb.PlaceholderColor3 = Color3.fromRGB(70,70,70)
	hb.Font = Enum.Font.Code; hb.TextSize = 12; hb.TextColor3 = Color3.fromRGB(190,190,190)
	hb.ClearTextOnFocus = false; hb.TextXAlignment = Enum.TextXAlignment.Center; hb.ZIndex = 11; hb.Parent = c
	Instance.new("UICorner", hb).CornerRadius = UDim.new(0, 5)
	local hbs = Instance.new("UIStroke"); hbs.Color = Color3.fromRGB(55,55,55); hbs.Thickness = 1; hbs.Parent = hb

	local function updateColor(newHex, fromPicker)
		currentHex = newHex; if tbl then tbl[key] = currentHex end
		sw.BackgroundColor3 = hexToColor3(currentHex); hb.PlaceholderText = "#"..currentHex
		if fromPicker then hb.Text = "" else hb.Text = "#"..currentHex end
	end

	hb.FocusLost:Connect(function()
		local raw = hb.Text:gsub("#",""):gsub("%s",""):upper()
		if raw == "" then updateColor(currentHex, true)
		elseif #raw == 6 and raw:match("^%x+$") then updateColor(raw, false)
			task.spawn(function() hbs.Color = Color3.fromRGB(255,255,255); task.wait(0.08); hbs.Color = Color3.fromRGB(55,55,55) end)
		else hb.Text = ""; task.spawn(function() hbs.Color = Color3.fromRGB(255,80,80); task.wait(0.3); hbs.Color = Color3.fromRGB(55,55,55) end) end
	end)
	hb.Focused:Connect(function() TweenService:Create(hbs, TweenInfo.new(0.1), {Color = Color3.fromRGB(160,160,160)}):Play() end)

	-- Single click: open color picker
	sw.MouseButton1Click:Connect(function()
		if rainbowActive then
			rainbowActive = false
			if rainbowConn then rainbowConn:Disconnect(); rainbowConn = nil end
			return
		end
		openColorPicker(hexToColor3(currentHex), function(c3)
			updateColor(color3ToHex(c3), true)
		end)
	end)

	-- Double click: toggle rainbow
	local lastClick = 0
	sw.MouseButton1Click:Connect(function()
		local now = tick()
		if now - lastClick < 0.35 then
			-- Double click detected
			if rainbowActive then
				rainbowActive = false
				if rainbowConn then rainbowConn:Disconnect(); rainbowConn = nil end
			else
				rainbowActive = true
				cp.Visible = false; pickerActive = false
				rainbowConn = RunService.Heartbeat:Connect(function()
					if not rainbowActive then return end
					local hue = (tick() * 0.5) % 1
					local c3 = Color3.fromHSV(hue, 1, 1)
					sw.BackgroundColor3 = c3
					local hex = color3ToHex(c3)
					if tbl then tbl[key] = hex end
					hb.PlaceholderText = "#"..hex; hb.Text = ""
				end)
			end
		end
		lastClick = now
	end)

	-- Middle click (scrollwheel click): toggle rainbow — use InputBegan on the swatch directly
	sw.InputBegan:Connect(function(input)
		if input.UserInputType == Enum.UserInputType.MouseButton3 then
			if rainbowActive then
				rainbowActive = false
				if rainbowConn then rainbowConn:Disconnect(); rainbowConn = nil end
			else
				rainbowActive = true
				cp.Visible = false; pickerActive = false
				rainbowConn = RunService.Heartbeat:Connect(function()
					if not rainbowActive then return end
					local hue = (tick() * 0.5) % 1
					local c3 = Color3.fromHSV(hue, 1, 1)
					sw.BackgroundColor3 = c3
					local hex = color3ToHex(c3)
					if tbl then tbl[key] = hex end
					hb.PlaceholderText = "#"..hex; hb.Text = ""
				end)
			end
		end
	end)
end

-- Exclusion manager with corner-style tags and autocomplete
local function createExclusionManager(order, parent)
	local c = Instance.new("Frame"); c.LayoutOrder = order; c.Size = UDim2.new(1, 0, 0, 86); c.BackgroundTransparency = 1; c.ZIndex = 10; c.Parent = parent

	local lb = Instance.new("TextLabel"); lb.BackgroundTransparency = 1; lb.Size = UDim2.new(1, 0, 0, 14)
	lb.Text = "Exclusions"; lb.TextColor3 = Color3.fromRGB(160,160,160)
	lb.Font = Enum.Font.GothamMedium; lb.TextSize = 12; lb.TextXAlignment = Enum.TextXAlignment.Left; lb.ZIndex = 10; lb.Parent = c

	local inputRow = Instance.new("Frame"); inputRow.Size = UDim2.new(1, 0, 0, 24); inputRow.Position = UDim2.new(0, 0, 0, 18)
	inputRow.BackgroundTransparency = 1; inputRow.ZIndex = 10; inputRow.Parent = c

	local boxContainer = Instance.new("Frame"); boxContainer.Size = UDim2.new(1, -55, 1, 0)
	boxContainer.BackgroundTransparency = 1; boxContainer.ClipsDescendants = true; boxContainer.ZIndex = 10; boxContainer.Parent = inputRow

	local box = Instance.new("TextBox"); box.Size = UDim2.new(1, 0, 1, 0)
	box.BackgroundColor3 = Color3.fromRGB(10,10,10); box.PlaceholderText = "Player name..."
	box.PlaceholderColor3 = Color3.fromRGB(70,70,70); box.Text = ""; box.Font = Enum.Font.GothamMedium
	box.TextSize = 12; box.TextColor3 = Color3.fromRGB(210,210,210); box.ClearTextOnFocus = false
	box.TextXAlignment = Enum.TextXAlignment.Left; box.ZIndex = 11; box.Parent = boxContainer
	Instance.new("UICorner", box).CornerRadius = UDim.new(0, 5)
	Instance.new("UIStroke", box).Color = Color3.fromRGB(55,55,55)
	Instance.new("UIPadding", box).PaddingLeft = UDim.new(0, 8)

	local ghostLabel = Instance.new("TextLabel"); ghostLabel.Size = UDim2.new(1, 0, 1, 0)
	ghostLabel.BackgroundTransparency = 1; ghostLabel.Text = ""; ghostLabel.Font = Enum.Font.GothamMedium
	ghostLabel.TextSize = 12; ghostLabel.TextColor3 = Color3.fromRGB(55,55,55)
	ghostLabel.TextXAlignment = Enum.TextXAlignment.Left; ghostLabel.ZIndex = 10
	ghostLabel.TextTransparency = 0.5; ghostLabel.Parent = boxContainer
	Instance.new("UIPadding", ghostLabel).PaddingLeft = UDim.new(0, 8)

	local currentSuggestion = nil

	local addBtn = Instance.new("TextButton"); addBtn.Size = UDim2.new(0, 48, 1, 0); addBtn.Position = UDim2.new(1, -48, 0, 0)
	addBtn.BackgroundColor3 = Color3.fromRGB(10,10,10); addBtn.Text = "+ Add"; addBtn.Font = Enum.Font.GothamBold
	addBtn.TextSize = 11; addBtn.TextColor3 = Color3.fromRGB(190,190,190); addBtn.AutoButtonColor = false; addBtn.ZIndex = 11; addBtn.Parent = inputRow
	Instance.new("UICorner", addBtn).CornerRadius = UDim.new(0, 5)
	local abs = Instance.new("UIStroke"); abs.Color = Color3.fromRGB(55,55,55); abs.Thickness = 1; abs.Parent = addBtn

	local tagsFrame = Instance.new("Frame"); tagsFrame.Size = UDim2.new(1, 0, 0, 38)
	tagsFrame.Position = UDim2.new(0, 0, 0, 46); tagsFrame.BackgroundTransparency = 1; tagsFrame.ZIndex = 10; tagsFrame.Parent = c
	local tagsLayout = Instance.new("UIListLayout"); tagsLayout.FillDirection = Enum.FillDirection.Horizontal
	tagsLayout.Padding = UDim.new(0, 5); tagsLayout.SortOrder = Enum.SortOrder.LayoutOrder
	tagsLayout.VerticalAlignment = Enum.VerticalAlignment.Top; tagsLayout.Wraps = true; tagsLayout.Parent = tagsFrame

	local function refreshTags()
		for _, child in ipairs(tagsFrame:GetChildren()) do
			if child:IsA("TextButton") or child.Name == "NoTag" then child:Destroy() end
		end
		if #Settings.Exclusions == 0 then
			local noTag = Instance.new("TextLabel"); noTag.Name = "NoTag"; noTag.BackgroundTransparency = 1
			noTag.Size = UDim2.new(1, 0, 0, 14); noTag.Text = "No exclusions"
			noTag.TextColor3 = Color3.fromRGB(70,70,70); noTag.Font = Enum.Font.Code; noTag.TextSize = 11
			noTag.TextXAlignment = Enum.TextXAlignment.Left; noTag.ZIndex = 10; noTag.Parent = tagsFrame
			return
		end
		for idx, name in ipairs(Settings.Exclusions) do
			local tag = Instance.new("TextButton")
			tag.Size = UDim2.new(0, #name * 7 + 20, 0, 20)
			tag.BackgroundColor3 = Color3.fromRGB(12,12,12)
			tag.BackgroundTransparency = 0.3
			tag.Text = name; tag.Font = Enum.Font.Code; tag.TextSize = 11
			tag.TextColor3 = Color3.fromRGB(170,170,170)
			tag.AutoButtonColor = false; tag.ZIndex = 11; tag.LayoutOrder = idx; tag.Parent = tagsFrame

			addCornerBorder(tag, Color3.fromRGB(60,60,60), 1, 6)

			tag.MouseEnter:Connect(function()
				TweenService:Create(tag, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(255,80,80), BackgroundColor3 = Color3.fromRGB(35,10,10)}):Play()
				tag.Text = name.." ✕"
			end)
			tag.MouseLeave:Connect(function()
				TweenService:Create(tag, TweenInfo.new(0.12), {TextColor3 = Color3.fromRGB(170,170,170), BackgroundColor3 = Color3.fromRGB(12,12,12)}):Play()
				tag.Text = name
			end)
			tag.MouseButton1Click:Connect(function()
				for i, v in ipairs(Settings.Exclusions) do if v == name then table.remove(Settings.Exclusions, i); break end end
				refreshTags()
			end)
		end
	end
	refreshTags()

	local function findSuggestion(partial)
		if #partial == 0 then return nil end
		for _, player in ipairs(Players:GetPlayers()) do
			if player ~= LocalPlayer then
				if player.Name:lower():sub(1, #partial) == partial:lower() then return player.Name end
				if player.DisplayName:lower():sub(1, #partial) == partial:lower() then return player.DisplayName end
			end
		end
		return nil
	end

	box:GetPropertyChangedSignal("Text"):Connect(function()
		local typed = box.Text
		if #typed > 0 then
			local suggestion = findSuggestion(typed)
			if suggestion then ghostLabel.Text = suggestion; currentSuggestion = suggestion
			else ghostLabel.Text = ""; currentSuggestion = nil end
		else ghostLabel.Text = ""; currentSuggestion = nil end
	end)

	local function addExclusion()
		local name = box.Text:gsub("^%s+",""):gsub("%s+$","")
		if #name == 0 and currentSuggestion then name = currentSuggestion end
		if #name > 0 then
			for _, v in ipairs(Settings.Exclusions) do if v:lower() == name:lower() then return end end
			table.insert(Settings.Exclusions, name)
			box.Text = ""; ghostLabel.Text = ""; currentSuggestion = nil; refreshTags()
			task.spawn(function() abs.Color = Color3.fromRGB(255,255,255); task.wait(0.1); abs.Color = Color3.fromRGB(55,55,55) end)
		end
	end

	addBtn.MouseButton1Click:Connect(addExclusion)
	addBtn.MouseEnter:Connect(function() TweenService:Create(abs, TweenInfo.new(0.1), {Color = Color3.fromRGB(140,140,140)}):Play() end)
	addBtn.MouseLeave:Connect(function() TweenService:Create(abs, TweenInfo.new(0.1), {Color = Color3.fromRGB(55,55,55)}):Play() end)

	box.FocusLost:Connect(function(enterPressed)
		if enterPressed then
			if currentSuggestion and #box.Text > 0 then
				box.Text = currentSuggestion; ghostLabel.Text = ""
				task.wait(0.05); addExclusion()
			elseif #box.Text:gsub("%s","") > 0 then addExclusion() end
		end
	end)
end

